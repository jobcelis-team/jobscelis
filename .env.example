# ============================================
# STREAMFLIX - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# cp .env.example .env
# ============================================

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=streamflix
APP_ENV=dev
MIX_ENV=dev
PORT=4000
# Host público: jobcelis.com (producción). En local usa localhost
PHX_HOST=jobcelis.com

# ============================================
# SECURITY KEYS (REQUIRED - Generate these!)
# ============================================
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=GENERATE_WITH_MIX_PHX_GEN_SECRET

# Generate with: mix guardian.gen.secret
GUARDIAN_SECRET_KEY=GENERATE_WITH_MIX_GUARDIAN_GEN_SECRET

# Signing salt for LiveView sessions (at least 32 chars)
LIVE_VIEW_SIGNING_SALT=GENERATE_A_RANDOM_32_CHAR_STRING

# ============================================
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ============================================
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_password
DB_HOSTNAME=db.xxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_POOL_SIZE=10
DB_SSL=true

DATABASE_URL=ecto://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ============================================
# SUPABASE API (Optional)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# ============================================
# REDIS CONFIGURATION (Redis Cloud)
# ============================================
REDIS_HOST=redis-xxxxx.xxxxx.cloud.redislabs.com
REDIS_PORT=xxxxx
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0
REDIS_URL=redis://:password@redis-xxxxx.xxxxx.cloud.redislabs.com:xxxxx
REDIS_SSL=true

# ============================================
# AZURE BLOB STORAGE CONFIGURATION
# ============================================
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
AZURE_CDN_ENDPOINT=https://your-account.blob.core.windows.net

# Container names
AZURE_CONTAINER_VIDEOS=videos
AZURE_CONTAINER_THUMBNAILS=thumbnails
AZURE_CONTAINER_MANIFESTS=manifests
AZURE_CONTAINER_ORIGINALS=originals

# Video playback (SAS URL - read-only, for reproducing videos)
# Base URL of the videos container (no trailing slash)
AZURE_VIDEOS_BASE_URL=https://stresssss.net/videos
# SAS token for container-level read access (sp=r, sr=c)
# Example: test
AZURE_VIDEOS_SAS_TOKEN=sp=tesd

# ============================================
# CLUSTERING CONFIGURATION
# ============================================
NODE_NAME=streamflix
NODE_COOKIE=change_this_to_a_secure_cookie
CLUSTER_STRATEGY=epmd

# For Kubernetes
KUBERNETES_NAMESPACE=production
KUBERNETES_SELECTOR=app=streamflix
KUBERNETES_NODE_BASENAME=streamflix

# ============================================
# STREAMING CONFIGURATION
# ============================================
MAX_STREAMS_BASIC=1
MAX_STREAMS_STANDARD=2
MAX_STREAMS_PREMIUM=4
HEARTBEAT_INTERVAL=10000
SESSION_TIMEOUT=300000

# ============================================
# OBAN (Background Jobs)
# ============================================
OBAN_QUEUE_DEFAULT=10
OBAN_QUEUE_TRANSCODING=2
OBAN_QUEUE_NOTIFICATIONS=5
OBAN_QUEUE_ANALYTICS=3

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_GC_INTERVAL=3600000
CACHE_MAX_SIZE=1000000
CACHE_ALLOCATED_MEMORY=500000000

# ============================================
# PAYMENTS (Optional - Stripe)
# ============================================
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================
# MONITORING (Optional)
# ============================================
METRICS_ENABLED=true
GRAFANA_PASSWORD=admin

# ============================================
# LEGAL / CONTACT / DONATIONS (Optional - override config)
# ============================================
# LEGAL_OWNER=Tu Nombre
# LEGAL_PRODUCT_NAME=Jobcelis
# LEGAL_CONTACT_EMAIL=tu@email.com
# DONATION_PAYPAL_URL=https://paypal.me/TU_USUARIO
# DONATION_PAYONEER_URL=https://payoneer.com/... (tu enlace de donación)

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_TWO_FACTOR_AUTH=false
MAINTENANCE_MODE=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
