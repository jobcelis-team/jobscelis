msgstr "Actualiza un webhook. Body: cualquiera de url, secret, topics, filters, body_config, headers, status."

msgid "Desactiva el webhook. Respuesta 200: status: \"inactive\"."
msgstr "Desactiva el webhook. Respuesta 200: status: \"inactive\"."

msgid "Envíos de eventos a webhooks. Sustituye DELIVERY_ID por el id del delivery."
msgstr "Envíos de eventos a webhooks. Sustituye DELIVERY_ID por el id del delivery."

