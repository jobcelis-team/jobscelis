<!DOCTYPE html>
<html lang={assigns[:locale] || "es"} class="scroll-smooth">
  <head>
    <script>
      (function(){
        var l = localStorage.getItem("locale") || document.cookie.replace(/(?:(?:^|.*;\s*)locale\s*=\s*([^;]*).*$)|^.*$/, "$1");
        if (l === "es" || l === "en") document.documentElement.lang = l;
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Favicon: logo en pestaña y en resultados de búsqueda (Google) --%>
    <link rel="icon" type="image/png" sizes="48x48" href={~p"/images/favicon-48x48.png"} />
    <link rel="icon" type="image/png" sizes="192x192" href={~p"/images/logo.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/logo.png"} />
    <meta name="theme-color" content="#0f172a" /> <%!-- SEO: Brand and Open Graph --%>
    <meta name="application-name" content="Jobcelis" />
    <meta
      name="description"
      content="Events, webhooks and scheduled jobs platform for developers. Send events with a simple POST and trigger webhooks in real time."
    /> <meta property="og:site_name" content="Jobcelis" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jobcelis.com" />
    <meta property="og:title" content="Jobcelis · Events, webhooks and jobs" />
    <meta
      property="og:description"
      content="Events, webhooks and scheduled jobs platform for developers."
    /> <meta property="og:image" content="https://jobcelis.com/images/logo.png" />
    <%!-- Twitter Cards --%> <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Jobcelis · Events, webhooks and jobs" />
    <meta
      name="twitter:description"
      content="Events, webhooks and scheduled jobs platform for developers."
    /> <meta name="twitter:image" content="https://jobcelis.com/images/logo.png" />
    <%!-- Schema.org: For Google to recognize logo and application type --%>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Jobcelis",
        "url": "https://jobcelis.com",
        "logo": "https://jobcelis.com/images/logo.png",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Web",
        "description": "Events, webhooks and scheduled jobs platform for developers. Send events with a simple POST and trigger webhooks in real time."
      }
    </script>

    <.live_title default="Jobcelis" suffix=" · Eventos, webhooks y jobs">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>

    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>

  <body>{@inner_content}</body>
</html>
