msgstr "Query and update the project; manage API Key. All routes require API Key."

msgid "Devuelve el proyecto: id, name, status, settings."
msgstr "Returns the project: id, name, status, settings."

msgid "Actualiza el proyecto. Body: name, settings (objeto). Respuesta: id, name, status."
msgstr "Update the project. Body: name, settings (object). Response: id, name, status."

