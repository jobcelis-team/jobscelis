# ============================================
# STREAMFLIX .GITIGNORE
# ============================================

# ============================================
# ENVIRONMENT FILES - CRITICAL SECURITY
# ============================================
# NEVER commit .env files with real credentials!
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
*.env

# Keep .env.example as reference
!.env.example

# ============================================
# ELIXIR/ERLANG BUILD ARTIFACTS
# ============================================
/_build/
/deps/
*.ez
*.beam
erl_crash.dump
*.plt
*.plt.hash

# ============================================
# PHOENIX ASSETS
# ============================================
/apps/*/priv/static/assets/
/priv/static/assets/
/apps/streamflix_web/assets/node_modules/
node_modules/

# ============================================
# DATABASE
# ============================================
*.db
*.db-journal
*.sqlite
*.sqlite3

# ============================================
# DOCUMENTATION
# ============================================
/doc/

