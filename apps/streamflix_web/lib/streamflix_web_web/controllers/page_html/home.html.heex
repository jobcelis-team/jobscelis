<Layouts.public
  flash={@flash}
  current_user={@current_user}
  locale={@locale}
  legal={@legal}
  active_page={@active_page}
  main_class="flex-1"
>
  <%!-- Hero --%>
  <section
    class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-24 md:pt-24 md:pb-32"
    aria-label={gettext("Presentación")}
  >
    <div
      class="absolute inset-0 bg-gradient-to-b from-indigo-50/60 via-transparent to-transparent dark:from-indigo-950/30 pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div class="relative text-center max-w-3xl mx-auto">
      <p class="text-indigo-600 dark:text-indigo-400 font-semibold text-sm uppercase tracking-wider mb-4">
        {gettext("La infraestructura de webhooks que no quieres reconstruir")}
      </p>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-slate-100 mb-6 leading-tight tracking-tight">
        {gettext("Conecta tus aplicaciones con eventos, sin complicaciones")}
      </h1>

      <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
        {gettext(
          "Cada vez que una app necesita notificar a otra, terminas escribiendo la misma lógica: llamadas HTTP, reintentos, manejo de fallos, logs. Jobcelis centraliza todo eso en una API. Envía un POST, nosotros lo entregamos al destino correcto."
        )}
      </p>

      <p class="text-sm text-slate-500 dark:text-slate-500 mb-10">
        {gettext(
          "Para: notificaciones de pago, procesamiento de pedidos, triggers CI/CD, integraciones SaaS, y más."
        )}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/signup"
          class="inline-flex items-center justify-center bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-xl font-semibold text-base transition shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30"
        >
          {gettext("Envía tu primer evento (gratis)")}
          <svg
            class="ml-2 w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"
            />
          </svg>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center justify-center bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:border-slate-300 dark:hover:border-slate-500 hover:bg-slate-50 dark:hover:bg-slate-700 px-8 py-4 rounded-xl font-semibold text-base transition"
        >
          {gettext("Cómo funciona")}
        </a>
      </div>
    </div>
  </section>
  <%!-- Code example --%>
  <section class="hero-code-section py-16" id="hero-code-demo">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl font-semibold text-center mb-2 hero-code-title">
        {gettext("Un POST, un evento")}
      </h2>

      <p class="text-center mb-8 text-sm hero-code-subtitle">
        {gettext("Envía eventos a Jobcelis desde cualquier lenguaje o framework.")}
      </p>

      <div class="hero-code-block rounded-2xl overflow-hidden max-w-2xl mx-auto">
        <%!-- Language tabs --%>
        <div class="hero-code-tabs flex overflow-x-auto">
          <button class="hero-code-tab active" data-lang="curl">cURL</button>
          <button class="hero-code-tab" data-lang="node">Node.js</button>
          <button class="hero-code-tab" data-lang="python">Python</button>
          <button class="hero-code-tab" data-lang="go">Go</button>
          <button class="hero-code-tab" data-lang="php">PHP</button>
          <button class="hero-code-tab" data-lang="ruby">Ruby</button>
          <button class="hero-code-tab" data-lang="elixir">Elixir</button>
        </div>
        <%!-- Code + response area --%>
        <div class="p-6 md:p-8 font-mono text-[0.8125rem] md:text-sm">
          <%!-- Code panels --%>
          <div class="overflow-x-auto" id="hero-code-panels">
            <pre class="leading-relaxed hero-code-text" data-panel="curl"><span class="hero-code-cmd">curl</span> -X POST https://jobcelis.com/api/v1/events \
  -H <span class="hero-code-string">"Authorization: Bearer YOUR_TOKEN"</span> \
  -H <span class="hero-code-string">"Content-Type: application/json"</span> \
  -d <span class="hero-code-string">'&#123;
    "topic": "user.signup",
    "payload": &#123; "user_id": "u_123", "plan": "free" &#125;
  &#125;'</span></pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="node"><span class="hero-code-keyword">import</span> <span class="hero-code-cmd">Jobcelis</span> <span class="hero-code-keyword">from</span> <span class="hero-code-string">"@jobcelis/sdk"</span>;

<span class="hero-code-keyword">const</span> client = <span class="hero-code-keyword">new</span> <span class="hero-code-cmd">Jobcelis</span>(<span class="hero-code-string">"YOUR_TOKEN"</span>);

<span class="hero-code-keyword">const</span> res = <span class="hero-code-keyword">await</span> client.<span class="hero-code-cmd">sendEvent</span>(<span class="hero-code-string">"user.signup"</span>, &#123;
  user_id: <span class="hero-code-string">"u_123"</span>,
  plan: <span class="hero-code-string">"free"</span>
&#125;);
console.<span class="hero-code-cmd">log</span>(res);</pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="python"><span class="hero-code-keyword">from</span> jobcelis <span class="hero-code-keyword">import</span> <span class="hero-code-cmd">Jobcelis</span>

client = <span class="hero-code-cmd">Jobcelis</span>(<span class="hero-code-string">"YOUR_TOKEN"</span>)

res = client.<span class="hero-code-cmd">send_event</span>(<span class="hero-code-string">"user.signup"</span>, &#123;
    <span class="hero-code-string">"user_id"</span>: <span class="hero-code-string">"u_123"</span>,
    <span class="hero-code-string">"plan"</span>: <span class="hero-code-string">"free"</span>
&#125;)
<span class="hero-code-cmd">print</span>(res)</pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="go">client := jobcelis.<span class="hero-code-cmd">New</span>(<span class="hero-code-string">"YOUR_TOKEN"</span>)

res, err := client.<span class="hero-code-cmd">SendEvent</span>(ctx, <span class="hero-code-string">"user.signup"</span>, map[string]any&#123;
    <span class="hero-code-string">"user_id"</span>: <span class="hero-code-string">"u_123"</span>,
    <span class="hero-code-string">"plan"</span>:    <span class="hero-code-string">"free"</span>,
&#125;)
fmt.<span class="hero-code-cmd">Println</span>(res)</pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="php"><span class="hero-code-keyword">use</span> <span class="hero-code-cmd">Jobcelis\Jobcelis</span>;

<span class="hero-code-variable">$client</span> = <span class="hero-code-keyword">new</span> <span class="hero-code-cmd">Jobcelis</span>(<span class="hero-code-string">"YOUR_TOKEN"</span>);

<span class="hero-code-variable">$res</span> = <span class="hero-code-variable">$client</span>-&gt;<span class="hero-code-cmd">sendEvent</span>(<span class="hero-code-string">"user.signup"</span>, [
    <span class="hero-code-string">"user_id"</span> =&gt; <span class="hero-code-string">"u_123"</span>,
    <span class="hero-code-string">"plan"</span>    =&gt; <span class="hero-code-string">"free"</span>,
]);
<span class="hero-code-cmd">var_dump</span>(<span class="hero-code-variable">$res</span>);</pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="ruby"><span class="hero-code-keyword">require</span> <span class="hero-code-string">"jobcelis"</span>

client = <span class="hero-code-cmd">Jobcelis</span>.<span class="hero-code-cmd">new</span>(<span class="hero-code-string">"YOUR_TOKEN"</span>)

res = client.<span class="hero-code-cmd">send_event</span>(<span class="hero-code-string">"user.signup"</span>, &#123;
  <span class="hero-code-string">user_id:</span> <span class="hero-code-string">"u_123"</span>,
  <span class="hero-code-string">plan:</span> <span class="hero-code-string">"free"</span>
&#125;)
<span class="hero-code-cmd">puts</span> res</pre>
            <pre class="leading-relaxed hero-code-text hidden" data-panel="elixir">client = <span class="hero-code-cmd">Jobcelis</span>.new(<span class="hero-code-string">"YOUR_TOKEN"</span>)

&#123;<span class="hero-code-keyword">:ok</span>, res&#125; = <span class="hero-code-cmd">Jobcelis</span>.<span class="hero-code-cmd">send_event</span>(client, <span class="hero-code-string">"user.signup"</span>, %&#123;
  <span class="hero-code-string">"user_id"</span> =&gt; <span class="hero-code-string">"u_123"</span>,
  <span class="hero-code-string">"plan"</span> =&gt; <span class="hero-code-string">"free"</span>
&#125;)
<span class="hero-code-cmd">IO.inspect</span>(res)</pre>
          </div>
          <%!-- Run button --%>
          <div class="mt-4 flex items-center gap-3">
            <button
              class="hero-run-btn flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-sans font-semibold transition"
              id="hero-run-btn"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
              {gettext("Ejecutar")}
            </button>
            <span class="hero-code-label text-xs font-sans" id="hero-run-status"></span>
          </div>
          <%!-- Response panel (hidden until run) --%>
          <div class="hidden mt-4" id="hero-response-area">
            <div class="hero-response-divider flex items-center gap-2 mb-3">
              <span class="hero-response-badge text-[0.6875rem] font-sans font-semibold px-2 py-0.5 rounded">
                201 Created
              </span>
              <span class="hero-response-time text-[0.6875rem] font-sans">~42ms</span>
            </div>

            <pre
              class="leading-relaxed hero-code-text hero-response-json"
              id="hero-response-json"
            ></pre>
          </div>
        </div>
      </div>

      <p class="text-center mt-4 text-xs hero-code-footer">
        {gettext("También disponible en")} .NET, Rust, Swift, Java, Dart, Kotlin + CLI
      </p>
    </div>
  </section>
  <%!-- How it works --%>
  <section
    id="how-it-works"
    class="border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 py-20 md:py-24"
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-slate-100 text-center mb-4">
        {gettext("Cómo funciona")}
      </h2>

      <p class="text-slate-600 dark:text-slate-400 text-center max-w-xl mx-auto mb-14">
        {gettext("De tu aplicación al destino, en cinco pasos.")}
      </p>

      <div class="grid md:grid-cols-5 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold">1</span>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Tu app envía un evento")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext("POST JSON a la API con tu token. Cualquier estructura, cualquier topic.")}
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold">2</span>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Jobcelis lo enruta")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext("Matchea webhooks por topic, wildcards o filtros de payload.")}
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold">3</span>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Tus endpoints lo reciben")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext("HTTP POST con el payload configurado y firma verificable.")}
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold">4</span>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("¿Falló? Reintentamos")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext("Backoff exponencial automático. Dead letters para las que no se recuperan.")}
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold">5</span>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Monitorea todo")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext("Dashboard, analytics, audit log y alertas en Slack, Discord o email.")}
          </p>
        </div>
      </div>
    </div>
  </section>
  <%!-- Use cases --%>
  <section class="border-t border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-900/50 py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-slate-100 text-center mb-4">
        {gettext("Casos de uso")}
      </h2>

      <p class="text-slate-600 dark:text-slate-400 text-center max-w-xl mx-auto mb-14">
        {gettext("Cómo otros developers usan Jobcelis para resolver problemas reales.")}
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"
              />
            </svg>
          </div>

          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Procesamiento de pedidos")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-3">
            {gettext(
              "Cuando un cliente hace un pedido, un solo evento notifica al warehouse, al sistema de facturación y al servicio de emails — automáticamente, con reintentos."
            )}
          </p>

          <span class="font-mono text-xs text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-1 rounded">
            "topic": "order.created"
          </span>
        </div>

        <div class="p-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </div>

          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Notificaciones de pago")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-3">
            {gettext(
              "Tu pasarela de pago envía un evento, Jobcelis actualiza el estado del pedido en tu backend y envía el recibo al cliente."
            )}
          </p>

          <span class="font-mono text-xs text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-1 rounded">
            "topic": "payment.completed"
          </span>
        </div>

        <div class="p-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
              />
            </svg>
          </div>

          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Triggers CI/CD")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-3">
            {gettext(
              "Cada deploy exitoso notifica al servicio de monitoreo, al canal de Slack y al tracker de analytics — sin código adicional."
            )}
          </p>

          <span class="font-mono text-xs text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-1 rounded">
            "topic": "deploy.success"
          </span>
        </div>

        <div class="p-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
              />
            </svg>
          </div>

          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Integraciones SaaS")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-3">
            {gettext(
              "Cuando un usuario se registra en tu plataforma, sincroniza con tu CRM, envía el email de bienvenida y registra en analytics."
            )}
          </p>

          <span class="font-mono text-xs text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-1 rounded">
            "topic": "user.signup"
          </span>
        </div>
      </div>
    </div>
  </section>
  <%!-- Features --%>
  <section class="border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-slate-100 text-center mb-4">
        {gettext("Todo lo que necesitas")}
      </h2>

      <p class="text-slate-600 dark:text-slate-400 text-center max-w-xl mx-auto mb-14">
        {gettext(
          "Empieza simple, escala con confianza. Desde el primer evento hasta flujos enterprise."
        )}
      </p>

      <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-4 mt-8">
        {gettext("Lo esencial")}
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="group p-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-indigo-200 dark:hover:border-indigo-700 hover:bg-indigo-50/30 dark:hover:bg-indigo-950/20 transition">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4 group-hover:bg-indigo-200/80 dark:group-hover:bg-indigo-800/50 transition">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
              />
            </svg>
          </div>

          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">
            {gettext("Eventos")}
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {gettext(
