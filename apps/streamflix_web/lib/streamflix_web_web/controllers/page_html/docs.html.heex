<Layouts.public
  flash={@flash}
  current_user={@current_user}
  locale={@locale}
  legal={@legal}
  active_page={@active_page}
  main_class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
>
  <div class="flex w-full gap-6 lg:gap-10 min-w-0">
    <%!-- Sidebar con grupos claros --%>
    <aside
      class="hidden lg:block w-64 shrink-0"
      aria-label={gettext("Navegación de la documentación")}
    >
      <nav class="sticky top-8 space-y-6 text-sm bg-white/80 backdrop-blur rounded-2xl border border-slate-200 shadow-sm p-5">
        <div>
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Visión general")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#intro"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Introducción")}
            </a>
            <a
              href="#concepts"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Conceptos básicos")}
            </a>
            <a
              href="#getting-started"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Primeros pasos")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Configuración")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#base-url"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Base URL")}
            </a>
            <a
              href="#auth"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Autenticación")}
            </a>
            <a
              href="#cors"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("CORS")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Cuenta y plataforma")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#account-management"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Gestión de cuenta")}
            </a>
            <a
              href="#password-recovery"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Recuperar contraseña")}
            </a>
            <a
              href="#dashboard-overview"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Dashboard")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Rutas públicas (Auth)")}
          </p>

          <div class="space-y-0.5 pl-1">
            <a
              href="#auth-register"
              class="block py-1.5 px-3 rounded-lg text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 transition text-xs font-mono"
            >
              POST /auth/register
            </a>
            <a
              href="#auth-login"
              class="block py-1.5 px-3 rounded-lg text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 transition text-xs font-mono"
            >
              POST /auth/login
            </a>
            <a
              href="#auth-refresh"
              class="block py-1.5 px-3 rounded-lg text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 transition text-xs font-mono"
            >
              POST /auth/refresh
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Referencia API")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#events"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Eventos")}
            </a>
            <a
              href="#webhooks"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Webhooks")}
            </a>
            <a
              href="#topic-wildcards"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Topic Wildcards")}
            </a>
            <a
              href="#deliveries"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Entregas")}
            </a>
            <a
              href="#jobs"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Jobs")}
            </a>
            <a
              href="#jobs-cron"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Configurar jobs y cron")}
            </a>
            <a
              href="#project-token"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Proyecto y token")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Funciones avanzadas")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#simulate"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Simulador")}
            </a>
            <a
              href="#webhook-health"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Webhook Health")}
            </a>
            <a
              href="#dead-letters"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Dead Letter Queue")}
            </a>
            <a
              href="#replays"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Event Replay")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Herramientas")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#sandbox"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Sandbox")}
            </a>
            <a
              href="#analytics"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Analíticas")}
            </a>
            <a
              href="#audit-log"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Audit Log")}
            </a>
            <a
              href="#health"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Health Check")}
            </a>
            <a
              href="#status-page"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Página de estado")}
            </a>
            <a
              href="#response-headers"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Headers de respuesta")}
            </a>
            <a
              href="#openapi"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("OpenAPI / Swagger")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Expansión")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#multi-project"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Multi-proyecto")}
            </a>
            <a
              href="#api-key-scopes"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Scopes de API Key")}
            </a>
            <a
              href="#event-schemas"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Event Schemas")}
            </a>
            <a
              href="#delayed-events"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Eventos diferidos")}
            </a>
            <a
              href="#realtime-stream"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Streaming SSE/WS")}
            </a>
            <a
              href="#teams"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Equipos")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Extras")}
          </p>

          <div class="space-y-0.5">
            <a
              href="#cursor-pagination"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Paginación cursor")}
            </a>
            <a
              href="#batch-events"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Batch Events")}
            </a>
            <a
              href="#export"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Exportar datos")}
            </a>
            <a
              href="#webhook-templates"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Plantillas webhook")}
            </a>
            <a
              href="#cron-preview"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Cron preview")}
            </a>
            <a
              href="#ip-allowlist"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("IP Allowlist")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <p class="font-bold text-slate-700 uppercase tracking-wider mb-2 px-2 text-xs">
            {gettext("Seguridad")}
          </p>
          <div class="space-y-0.5">
            <a
              href="#account-lockout"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Bloqueo de cuenta")}
            </a>
            <a
              href="#session-timeout"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Timeout de sesión")}
            </a>
            <a
              href="#mfa-totp"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("MFA / TOTP")}
            </a>
            <a
              href="#backups"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Backups automáticos")}
            </a>
            <a
              href="#data-protection"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Protección de datos")}
            </a>
            <a
              href="#ropa"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Registro de actividades (Art. 30)")}
            </a>
            <a
              href="#event-integrity"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Integridad de eventos")}
            </a>
            <a
              href="#password-policy"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Política de contraseñas")}
            </a>
            <a
              href="#uptime-monitoring"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Monitoreo de disponibilidad")}
            </a>
            <a
              href="#circuit-breaker"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Circuit breaker")}
            </a>
            <a
              href="#breach-detection"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Detección de brechas")}
            </a>
            <a
              href="#session-management"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Gestión de sesiones")}
            </a>
            <a
              href="#data-encryption"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Cifrado de datos PII")}
            </a>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <div class="space-y-0.5">
            <a
              href="#usage"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Formas de uso")}
            </a>
            <a
              href="#status-codes"
              class="block py-2 px-3 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition"
            >
              {gettext("Códigos de respuesta")}
            </a>
          </div>
        </div>
      </nav>
    </aside>

    <main class="docs-main min-w-0 flex-1 max-w-4xl overflow-hidden">
      <header class="mb-10">
        <h1 class="text-4xl font-bold text-slate-900 tracking-tight mb-3">
          {gettext("Documentación de la API")}
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl">
          {gettext(
            "Referencia completa: rutas, autenticación, CORS, ejemplos y qué probar en cada endpoint."
          )}
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="#getting-started"
            class="inline-flex items-center px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition"
          >
            {gettext("Primeros pasos")}
          </a>
          <a
            href="#events"
            class="inline-flex items-center px-4 py-2 rounded-xl bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition"
          >
            {gettext("Eventos")}
          </a>
          <a
            href="#webhooks"
            class="inline-flex items-center px-4 py-2 rounded-xl bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition"
          >
            {gettext("Webhooks")}
          </a>
        </div>
      </header>

      <section id="intro" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Introducción")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Qué es Jobcelis y qué puedes hacer con la API.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Jobcelis es una plataforma de eventos y webhooks 100% configurable. Envía cualquier JSON desde tu código; nosotros enrutamos, filtramos, transformamos y entregamos a tus URLs. Sin esquemas fijos: tú defines topics, payloads y reglas."
              )}
            </p>

            <div class="grid sm:grid-cols-2 gap-4">
              <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                <h3 class="font-semibold text-slate-900 mb-2 text-sm">
                  {gettext("Capacidades principales")}
                </h3>

                <ul class="text-slate-600 text-sm space-y-1.5">
                  <li>
                    <strong>{gettext("Eventos:")}</strong> {gettext(
                      "envía JSON con topic opcional vía POST. Sin esquemas fijos."
                    )}
                  </li>

                  <li>
                    <strong>{gettext("Webhooks:")}</strong> {gettext(
                      "URLs de destino, filtros (topic, amount, status), body_config (full, pick, rename, extra)."
                    )}
                  </li>

                  <li>
                    <strong>{gettext("Entregas:")}</strong> {gettext(
                      "reintentos automáticos con backoff exponencial."
                    )}
                  </li>

                  <li>
                    <strong>{gettext("Jobs:")}</strong> {gettext(
                      "daily, weekly, monthly o cron. Emitir evento o POST a URL."
                    )}
                  </li>

                  <li>
                    <strong>{gettext("Topics:")}</strong> {gettext(
                      "etiquetas para filtrar y organizar eventos."
                    )}
                  </li>
                </ul>
              </div>

              <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                <h3 class="font-semibold text-slate-900 mb-2 text-sm">
                  {gettext("Grupos de rutas")}
                </h3>

                <ul class="text-slate-600 text-sm space-y-1.5">
                  <li>
                    <strong>{gettext("Rutas públicas:")}</strong> {gettext(
                      "registro, login, refresh JWT. Sin API Key."
                    )}
                  </li>

                  <li>
                    <strong>{gettext("Rutas con API Key:")}</strong> {gettext(
                      "eventos, webhooks, deliveries, jobs, proyecto. Token en Dashboard."
                    )}
                  </li>
                </ul>

                <p class="text-slate-500 text-xs mt-3">
                  {gettext("Respuestas en JSON. CORS habilitado. Payload máximo 256 KB.")}
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="concepts" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Conceptos básicos")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Estos son los conceptos que necesitas para usar Jobcelis. No hace falta ser experto: con entender qué es cada cosa puedes configurar eventos, webhooks y jobs en pocos minutos."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 border-l-4 border-l-indigo-500 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("¿Qué es un evento?")}
              </h3>

              <p class="text-slate-700 leading-relaxed mb-4">
                {gettext(
                  "Un evento es un mensaje que tú envías a Jobcelis desde tu aplicación (con un POST). Puede ser cualquier JSON: un pedido, un pago, un clic, un registro, etc. Opcionalmente le pones un \"topic\" (etiqueta) para clasificarlo, por ejemplo \"order.created\" o \"payment.completed\". Jobcelis guarda el evento y, según los webhooks que tengas configurados, envía esa información a las URLs que tú indiques."
                )}
              </p>

              <p class="text-slate-500 text-xs font-medium uppercase tracking-wider mb-2">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >{"topic": "order.created", "order_id": 123, "total": 99.99}</pre>
            </div>

            <div class="rounded-xl border border-slate-200 border-l-4 border-l-indigo-500 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("¿Qué es un webhook?")}
              </h3>

              <p class="text-slate-700 leading-relaxed mb-4">
                {gettext(
                  "Un webhook es una URL de destino que tú configuras. Cuando llega un evento que cumple las condiciones (topic, filtros), Jobcelis hace un POST a esa URL con los datos que tú eliges (completos, solo ciertos campos, renombrados, etc.). Así tu servidor, tu otro sistema o un servicio externo recibe la información en tiempo real sin que tengas que consultar nada."
                )}
              </p>

              <p class="text-slate-500 text-xs font-medium uppercase tracking-wider mb-2">
                {gettext("Ejemplo")}
              </p>

              <p class="text-slate-600 text-sm">
                {gettext(
                  "Webhook a https://mi-app.com/recibir-pedidos solo cuando topic sea \"order.created\" y amount sea mayor que 50."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 border-l-4 border-l-indigo-500 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("¿Qué es una entrega (delivery)?")}
              </h3>

              <p class="text-slate-700 leading-relaxed mb-2">
                {gettext(
                  "Cada vez que Jobcelis intenta enviar un evento a una URL de webhook, se crea una \"entrega\" (delivery). Esa entrega tiene un estado: pendiente, éxito o fallo. Si falla (por ejemplo la URL no responde), Jobcelis reintenta automáticamente con backoff exponencial. En el dashboard puedes ver el historial de entregas y reintentar manualmente una que haya fallado."
                )}
              </p>

              <p class="text-slate-500 text-sm italic">
                {gettext(
                  "Resumen: 1 evento puede generar varias entregas (una por webhook que coincida); cada entrega es un intento de POST a una URL."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 border-l-4 border-l-indigo-500 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("¿Qué es un job (tarea programada)?")}
              </h3>

              <p class="text-slate-700 leading-relaxed mb-4">
                {gettext(
                  "Un job es una tarea que se ejecuta automáticamente en un horario que tú defines: cada día a una hora, cada semana un día concreto, cada mes, o con una expresión cron (por ejemplo \"cada 15 minutos\" o \"todos los lunes a las 9:00\"). Cuando se ejecuta, el job puede hacer una de dos cosas: emitir un evento interno (que luego pasa por tus webhooks) o hacer un POST a una URL que tú indiques. Así no necesitas tener un cron en tu servidor: Jobcelis hace la llamada por ti."
                )}
              </p>

              <p class="text-slate-500 text-xs font-medium uppercase tracking-wider mb-2">
                {gettext("Ejemplo")}
              </p>

              <p class="text-slate-600 text-sm">
                {gettext(
                  "Job \"Resumen diario\" que cada día a las 00:00 emite un evento con topic \"report.daily\"; tus webhooks lo reciben y tu sistema genera el informe."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 border-l-4 border-l-indigo-500 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("¿Qué es un topic?")}
              </h3>

              <p class="text-slate-700 leading-relaxed">
                {gettext(
                  "El topic es una etiqueta opcional que pones al enviar un evento (por ejemplo \"order.created\", \"payment.completed\"). Sirve para filtrar: en un webhook puedes decir \"solo quiero recibir eventos con topic X\" o combinar topic con filtros (por ejemplo amount mayor que 100). Tú inventas los nombres; no hay lista fija."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="getting-started" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Primeros pasos")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Sigue estos pasos para tener todo funcionando en pocos minutos.")}
            </p>
          </div>

          <div class="p-8 space-y-6">
            <div class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200 transition">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 font-bold flex items-center justify-center text-lg">
                1
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-slate-900 mb-1">
                  {gettext("Regístrate e inicia sesión")}
                </h3>

                <p class="text-slate-600 text-sm leading-relaxed">
                  {gettext("En la web, regístrate con tu email y contraseña. Entra al Dashboard.")}
                </p>
              </div>
            </div>

            <div class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200 transition">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 font-bold flex items-center justify-center text-lg">
                2
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-slate-900 mb-1">{gettext("Copia tu API Token")}</h3>

                <p class="text-slate-600 text-sm leading-relaxed">
                  {gettext(
                    "En el Dashboard, sección API Token, verás el token (o prefix). Si acabas de registrarte, el token se habrá mostrado al crear el proyecto. Guárdalo; lo usarás en todas las peticiones con header Authorization: Bearer TU_TOKEN o X-Api-Key: TU_TOKEN."
                  )}
                </p>
              </div>
            </div>

            <div class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200 transition">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 font-bold flex items-center justify-center text-lg">
                3
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-slate-900 mb-1">
                  {gettext("Envía tu primer evento")}
                </h3>

                <p class="text-slate-600 text-sm leading-relaxed mb-3">
                  {gettext(
                    "Desde tu código o con curl: POST /api/v1/events con body JSON (por ejemplo {\"topic\":\"test\",\"message\":\"Hola\"}). En el Dashboard podrás ver el evento en la lista."
                  )}
                </p>

                <div class="min-w-0 overflow-x-auto rounded-lg">
                  <pre class="bg-slate-800 text-slate-100 p-3 rounded-lg text-xs font-mono whitespace-pre">curl -X POST "BASE_URL/api/v1/events" -H "Authorization: Bearer TU_TOKEN" -H "Content-Type: application/json" -d '<%= "{\"topic\":\"test\",\"message\":\"" %><%= gettext("Hola") %><%= "\"}" %>'</pre>
                </div>
              </div>
            </div>

            <div class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200 transition">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 font-bold flex items-center justify-center text-lg">
                4
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-slate-900 mb-1">{gettext("Crea un webhook")}</h3>

                <p class="text-slate-600 text-sm leading-relaxed">
                  {gettext(
                    "En el Dashboard, Webhooks → Crear. Pon una URL que pueda recibir POST (puedes usar webhook.site). Opcional: elige un topic (ej. test) para que solo los eventos con ese topic lleguen a esa URL. Guarda y envía otro evento de prueba."
                  )}
                </p>
              </div>
            </div>

            <div class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200 transition">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-slate-100 text-slate-600 font-bold flex items-center justify-center text-lg">
                5
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-slate-900 mb-1">
                  {gettext("Crea un job (opcional)")}
                </h3>

                <p class="text-slate-600 text-sm leading-relaxed">
                  {gettext(
                    "En el Dashboard, Jobs → Crear. Elige programación (por ejemplo Diario a las 12:00) y acción (emitir evento o POST a URL). Guarda; el job se ejecutará a la hora indicada. En \"Configurar jobs y cron\" más abajo tienes la guía de cron y ejemplos."
                  )}
                </p>
              </div>
            </div>

            <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
              {gettext(
                "Si algo falla, revisa que el token esté bien en el header y que la URL del webhook sea accesible (HTTPS en producción). Las entregas fallidas se pueden reintentar desde el Dashboard."
              )}
            </div>
          </div>
        </div>
      </section>

      <section id="base-url" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Base URL")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Todos los ejemplos de esta documentación usan la base URL actual (dinámica):"
              )}
            </p>
          </div>

          <div class="p-8">
            <code class="block bg-slate-800 text-slate-100 px-5 py-4 rounded-xl font-mono text-sm break-all border border-slate-700">
              {@base_url}
            </code>
            <p class="text-slate-600 text-sm mt-4">
              {gettext(
                "En producción la base URL será tu dominio (ej. https://api.tudominio.com). Los ejemplos curl que ves en cada ruta ya incluyen esta base."
              )}
            </p>
          </div>
        </div>
      </section>

      <section id="auth" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Autenticación")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Cómo enviar el API Key o usar JWT en las peticiones.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Rutas con API Key (Jobcelis)")}
              </h3>

              <p class="text-slate-600 mb-3">
                {gettext("Puedes enviar el token de dos maneras (una por petición):")}
              </p>

              <ol class="list-decimal list-inside text-slate-700 space-y-2 mb-3">
                <li>
                  {gettext("Header")}
                  <code class="bg-slate-100 px-2 py-1 rounded font-mono text-sm">
                    Authorization: Bearer &lt;{gettext("tu_token")}&gt;
                  </code>
                </li>

                <li>
                  {gettext("Header")}
                  <code class="bg-slate-100 px-2 py-1 rounded font-mono text-sm">
                    X-Api-Key: &lt;{gettext("tu_token")}&gt;
                  </code>
                </li>

                <li>
                  {gettext("Query param (para descargas desde el navegador)")}
                  <code class="bg-slate-100 px-2 py-1 rounded font-mono text-sm">
                    ?api_key=&lt;{gettext("tu_token")}&gt;
                  </code>
                </li>
              </ol>

              <p class="text-slate-600 text-sm">
                {gettext(
                  "El token se obtiene en el Dashboard (sección API Token), al crear o regenerar. El valor completo solo se muestra una vez; guárdalo. Si regeneras, el token anterior deja de funcionar."
                )}
              </p>
            </div>

            <div class="border-t border-slate-200 pt-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Rutas públicas (Auth)")}
              </h3>

              <p class="text-slate-600 text-sm">
                {gettext(
                  "No envíes API Key. Registro y login devuelven un token (JWT) para usar en tu app web; el refresh renueva ese JWT."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="cors" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("CORS")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Uso de la API desde el navegador u otros orígenes.")}
            </p>
          </div>

          <div class="p-8 space-y-4">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "La API tiene CORS habilitado para cualquier origen (Access-Control-Allow-Origin: *). Así, cualquier frontend (tu SPA, otra web, móvil con WebView, etc.) puede consumir la API desde su propia URL sin bloqueos del navegador."
              )}
            </p>

            <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
              <p class="font-medium text-slate-800 mb-2 text-sm">
                {gettext("Headers permitidos en peticiones cross-origin:")}
              </p>

              <ul class="text-slate-600 text-sm space-y-1">
                <li>
                  <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono">
                    Authorization
                  </code>
                  ({gettext("Bearer token")})
                </li>

                <li>
                  <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono">
                    X-Api-Key
                  </code>
                </li>

                <li>
                  <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono">Content-Type</code>,
                  <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono">
                    Accept
                  </code>
                </li>
              </ul>
            </div>

            <p class="text-slate-500 text-sm">
              {gettext(
                "Métodos: GET, POST, PUT, PATCH, DELETE, OPTIONS. Las peticiones preflight (OPTIONS) reciben 200 con los headers CORS."
              )}
            </p>
          </div>
        </div>
      </section>

      <section id="public-routes" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Rutas públicas (sin API Key)")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Registro, login y refresh de JWT. Body y respuesta en JSON.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div
              id="auth-register"
              class="rounded-xl border border-slate-200 bg-slate-50/50 p-6 scroll-mt-24"
            >
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/auth/register</code>
              </div>

              <p class="text-slate-700 text-sm mb-2">
                {gettext(
                  "Registra un usuario. Body: email (requerido), password (requerido), name (opcional)."
                )}
              </p>

              <p class="text-slate-500 text-xs mb-3">
                {gettext("Respuesta 201: user (id, email, name), token (JWT).")}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/auth/register" \
  -H "Content-Type: application/json" \
  -d '{"email":"user@example.com","password":"secret123","name":"User"}'</pre>
            </div>

            <div
              id="auth-login"
              class="rounded-xl border border-slate-200 bg-slate-50/50 p-6 scroll-mt-24"
            >
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/auth/login</code>
              </div>

              <p class="text-slate-700 text-sm mb-2">
                {gettext("Inicia sesión. Body: email, password.")}
              </p>

              <p class="text-slate-500 text-xs mb-3">
                {gettext("Respuesta 200: user, token (JWT). 401 si credenciales incorrectas.")}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/auth/login" \
  -H "Content-Type: application/json" \
  -d '{"email":"user@example.com","password":"secret123"}'</pre>
            </div>

            <div
              id="auth-refresh"
              class="rounded-xl border border-slate-200 bg-slate-50/50 p-6 scroll-mt-24"
            >
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/auth/refresh</code>
              </div>

              <p class="text-slate-700 text-sm mb-2">
                {gettext("Refresca el JWT. Body: token (JWT actual).")}
              </p>

              <p class="text-slate-500 text-xs mb-3">
                {gettext("Respuesta 200: token (nuevo JWT). 401 si token inválido o expirado.")}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X POST "<%= @base_url %>/api/v1/auth/refresh" \
  -H "Content-Type: application/json" \
  -d '<%= "{\"token\":\"" %><%= gettext("TU_JWT_AQUI") %><%= "\"}" %>'</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="events" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Eventos")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Todas las rutas requieren API Key. Sustituye YOUR_API_KEY y EVENT_ID por valores reales."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/send</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Alias para enviar un evento. Mismo body que POST /events. Respuesta 202: event_id."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/send" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"topic":"payment.completed","amount":99}'</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/events</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Envía un evento. Body: cualquier JSON; opcional topic. Respuesta 202: event_id."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/events" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"topic":"order.created","order_id":123,"customer":"acme"}'</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/events</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista eventos. Query: topic, limit (1-100), include=inactive. Respuesta: events (array)."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/events?limit=10" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/events?topic=order.created&amp;limit=20" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/events/:id</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Detalle de un evento y sus deliveries. Sustituye EVENT_ID por el id del evento."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/events/EVENT_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                  DELETE
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/events/:id</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Desactiva el evento (soft delete). Respuesta 200: status: \"inactive\"."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X DELETE "<%= @base_url %>/api/v1/events/EVENT_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="webhooks" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Webhooks")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Configura URLs de destino. Opcional: topics (array), filters (path, op, value), body_config (body_mode, body_pick, body_rename, body_extra), headers."
              )}
            </p>
          </div>

          <div class="p-8 space-y-6">
            <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-sm">
              <p class="font-medium text-slate-800 mb-1">{gettext("Filtros:")}</p>

              <p class="text-slate-600 mb-2">
                {gettext("op: eq, neq, gte, lte, gt, lt, in, not_in, exists, contains. Ejemplo:")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-3 rounded-lg text-xs overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >{"filters":[{"path":"topic","op":"eq","value":"orders"},{"path":"payload.amount","op":"gte","value":100}]}</pre>
              <p class="font-medium text-slate-800 mt-3 mb-1">{gettext("body_config:")}</p>

              <p class="text-slate-600">
                {gettext(
                  "body_mode: full o pick. body_pick: array de campos. body_rename: {old: new}. body_extra: campos añadidos."
                )}
              </p>
            </div>

            <p class="text-slate-500 text-sm -mt-2">
              {gettext("Sustituye WEBHOOK_ID por el id del webhook.")}
            </p>

            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista webhooks del proyecto. Query: include=inactive. Respuesta: webhooks (array)."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/webhooks" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/webhooks?include=inactive" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Crea un webhook. Body: url (requerido), opcional secret, topics, filters, body_config, headers. Respuesta 201: objeto webhook."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/webhooks" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"url":"https://your-server.com/webhook","topics":["order.created","payment.completed"]}'</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/webhooks" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"url":"https://example.com/hook","secret":"my_secret","topics":["*"]}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Detalle de un webhook (id, url, status, topics, filters, etc.).")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/webhooks/WEBHOOK_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    PATCH
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Actualiza un webhook. Body: cualquiera de url, secret, topics, filters, body_config, headers, status."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X PATCH "<%= @base_url %>/api/v1/webhooks/WEBHOOK_ID" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"url":"https://new-url.com/webhook","status":"active"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    DELETE
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Desactiva el webhook. Respuesta 200: status: \"inactive\".")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X DELETE "<%= @base_url %>/api/v1/webhooks/WEBHOOK_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="topic-wildcards" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Topic Wildcards")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Usa patrones comodín en los topics de tus webhooks para suscribirte a múltiples eventos con una sola regla."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-indigo-500 bg-indigo-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Los topics usan notación de puntos (ej. \"order.created\"). Los wildcards permiten que un webhook reciba eventos de múltiples topics sin listarlos uno a uno."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Patrones disponibles")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">*</code>
                  — {gettext("Coincide con exactamente un segmento.")}
                  <span class="text-slate-500">
                    {gettext(
                      "Ej: \"order.*\" → order.created, order.updated (no order.item.created)"
                    )}
                  </span>
                </li>
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">#</code>
                  — {gettext("Coincide con uno o más segmentos.")}
                  <span class="text-slate-500">
                    {gettext(
                      "Ej: \"order.#\" → order.created, order.item.created, order.item.updated"
                    )}
                  </span>
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("Ejemplo")}</h3>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/webhooks" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"url":"https://your-server.com/hook","topics":["order.*","payment.#"]}'</pre>
              <p class="text-slate-500 text-xs mt-3">
                {gettext(
                  "Este webhook recibirá todos los eventos de order (un nivel) y todos los de payment (cualquier nivel de profundidad)."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="deliveries" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Entregas")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Envíos de eventos a webhooks. Sustituye DELIVERY_ID por el id del delivery."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/deliveries</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista deliveries. Query: event_id, webhook_id, status, limit (1-100). Respuesta: deliveries (array)."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/deliveries" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/deliveries?event_id=EVENT_ID&amp;status=failed&amp;limit=20" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/deliveries/:id/retry
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext("Reencola un envío fallido. Respuesta 200: status: \"retry_queued\".")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/deliveries/DELIVERY_ID/retry" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="jobs" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Jobs (tareas programadas)")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Tareas que se ejecutan según una programación: daily, weekly, monthly o cron. Acción: emitir evento interno o POST a una URL."
              )}
            </p>
          </div>

          <div class="p-8 space-y-6">
            <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-sm">
              <p class="font-medium text-slate-800 mb-2">
                {gettext("schedule_type + schedule_config")}
              </p>

              <ul
                class="text-slate-600 space-y-1 list-disc list-inside"
                phx-no-curly-interpolation
              >
                <li><strong>daily:</strong> {"hour": 14, "minute": 30}</li>

                <li>
                  <strong>weekly:</strong>
                  {"day_of_week": 1, "hour": 9, "minute": 0} (1=Lun, 7=Dom)
                </li>

                <li><strong>monthly:</strong> {"day_of_month": 1, "hour": 0, "minute": 0}</li>

                <li><strong>cron:</strong> {"expr": "0 0 * * *"} (min hour day month dow)</li>
              </ul>

              <p class="font-medium text-slate-800 mt-3 mb-2">
                {gettext("action_type + action_config")}
              </p>

              <ul
                class="text-slate-600 space-y-1 list-disc list-inside"
                phx-no-curly-interpolation
              >
                <li><strong>emit_event:</strong> {"topic": "report.daily", "payload": {}}</li>

                <li><strong>post_url:</strong> {"url": "https://...", "method": "POST"}</li>
              </ul>
            </div>

            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>

                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista jobs del proyecto. Query: include=inactive. Respuesta: jobs (array)."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/jobs" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/jobs?include=inactive" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>

                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Crea un job. Body: name, schedule_type, schedule_config, action_type, action_config. Respuesta 201: objeto job."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/jobs" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"name":"Daily report","schedule_type":"daily","schedule_config":{"hour":14,"minute":30},"action_type":"emit_event","action_config":{"topic":"report.daily","payload":{}}}'</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/jobs" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"name":"Weekly sync","schedule_type":"weekly","schedule_config":{"day_of_week":1,"hour":9,"minute":0},"action_type":"post_url","action_config":{"url":"https://api.example.com/sync","method":"POST"}}'</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/jobs" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"name":"Cron job","schedule_type":"cron","schedule_config":{"expr":"0 0 * * *"},"action_type":"emit_event","action_config":{"topic":"daily.cleanup"}}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Detalle del job y runs recientes. Respuesta incluye recent_runs.")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/jobs/JOB_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    PATCH
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Actualiza un job. Body: name, schedule_type, schedule_config, action_type, action_config, status."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X PATCH "<%= @base_url %>/api/v1/jobs/JOB_ID" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"name":"Updated job name","status":"active"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    DELETE
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Desactiva el job. Respuesta 200: status: \"inactive\".")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X DELETE "<%= @base_url %>/api/v1/jobs/JOB_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/jobs/:id/runs</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista ejecuciones del job. Query: limit (1-100). Respuesta: runs (array)."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/jobs/JOB_ID/runs" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre> <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                  phx-no-curly-interpolation
                >curl -X GET "<%= @base_url %>/api/v1/jobs/JOB_ID/runs?limit=50" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="jobs-cron" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Configurar jobs y cron")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Los jobs se programan de cuatro formas: diario, semanal, mensual o con una expresión cron. Aquí te explicamos cada una y cómo escribir expresiones cron si eliges esa opción."
              )}
            </p>
          </div>

          <div class="p-8 space-y-6">
            <h3 class="text-lg font-semibold text-slate-800">
              {gettext("Tipos de programación (schedule_type)")}
            </h3>

            <ul class="text-slate-700 text-sm space-y-2 mb-4 list-disc list-inside">
              <li>
                <strong>daily</strong>
                — {gettext(
                  "Cada día a la misma hora. Configuración: hour (0-23), minute (0-59). Ejemplo: 14:30 → {\"hour\": 14, \"minute\": 30}."
                )}
              </li>

              <li>
                <strong>weekly</strong>
                — {gettext(
                  "Un día de la semana a una hora. day_of_week: 1 = Lunes, 7 = Domingo. Ejemplo: Lunes 09:00 → {\"day_of_week\": 1, \"hour\": 9, \"minute\": 0}."
                )}
              </li>

              <li>
                <strong>monthly</strong>
                — {gettext(
                  "Un día del mes a una hora. day_of_month: 1-31. Ejemplo: Día 1 a las 00:00 → {\"day_of_month\": 1, \"hour\": 0, \"minute\": 0}."
                )}
              </li>

              <li>
                <strong>cron</strong>
                — {gettext(
                  "Expresión de 5 campos para máxima flexibilidad. Formato: minuto hora día_mes mes día_semana. Ver tabla abajo."
                )}
              </li>
            </ul>

            <h3 class="text-lg font-medium text-slate-800 mt-4 mb-2">
              {gettext("Expresiones cron: qué significa cada campo")}
            </h3>

            <p class="text-slate-600 text-sm mb-2">
              {gettext("Una expresión cron tiene 5 campos separados por espacio, en este orden:")}
            </p>

            <div class="overflow-x-auto mb-4">
              <table class="min-w-full border border-slate-200 rounded-lg text-sm">
                <thead class="bg-slate-100">
                  <tr>
                    <th class="px-3 py-2 text-left font-medium text-slate-700">
                      {gettext("Campo")}
                    </th>

                    <th class="px-3 py-2 text-left font-medium text-slate-700">
                      {gettext("Significado")}
                    </th>

                    <th class="px-3 py-2 text-left font-medium text-slate-700">
                      {gettext("Valores")}
                    </th>
                  </tr>
                </thead>

                <tbody class="text-slate-600">
                  <tr class="border-t border-slate-200">
                    <td class="px-3 py-2 font-mono">1º</td>

                    <td class="px-3 py-2">{gettext("Minuto")}</td>

                    <td class="px-3 py-2">0-59</td>
                  </tr>

                  <tr class="border-t border-slate-200">
                    <td class="px-3 py-2 font-mono">2º</td>

                    <td class="px-3 py-2">{gettext("Hora")}</td>

                    <td class="px-3 py-2">0-23</td>
                  </tr>

                  <tr class="border-t border-slate-200">
                    <td class="px-3 py-2 font-mono">3º</td>

                    <td class="px-3 py-2">{gettext("Día del mes")}</td>

                    <td class="px-3 py-2">1-31</td>
                  </tr>

                  <tr class="border-t border-slate-200">
                    <td class="px-3 py-2 font-mono">4º</td>

                    <td class="px-3 py-2">{gettext("Mes")}</td>

                    <td class="px-3 py-2">1-12</td>
                  </tr>

                  <tr class="border-t border-slate-200">
                    <td class="px-3 py-2 font-mono">5º</td>

                    <td class="px-3 py-2">{gettext("Día de la semana")}</td>

                    <td class="px-3 py-2">{gettext("1-7 (1=Lun, 7=Dom)")}</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p class="text-slate-600 text-sm mb-2">
              {gettext(
                "Puedes usar un número concreto, un asterisco (*) para \"cualquier valor\", o rangos (ej. 1-5 para lunes a viernes). Ejemplos:"
              )}
            </p>

            <ul class="text-slate-700 text-sm space-y-1 mb-4 list-disc list-inside">
              <li>
                <code class="bg-slate-100 px-0.5 rounded">0 0 * * *</code>
                — {gettext("Todos los días a medianoche (00:00).")}
              </li>

              <li>
                <code class="bg-slate-100 px-0.5 rounded">0 9 * * *</code>
                — {gettext("Todos los días a las 09:00.")}
              </li>

              <li>
                <code class="bg-slate-100 px-0.5 rounded">0 9 * * 1</code>
                — {gettext("Solo los lunes a las 09:00.")}
              </li>

              <li>
                <code class="bg-slate-100 px-0.5 rounded">0 9 * * 1-5</code>
                — {gettext("Días laborables (Lun–Vie) a las 09:00.")}
              </li>

              <li>
                <code class="bg-slate-100 px-0.5 rounded">*/15 * * * *</code>
                — {gettext("Cada 15 minutos.")}
              </li>

              <li>
                <code class="bg-slate-100 px-0.5 rounded">0 0 1 * *</code>
                — {gettext("El día 1 de cada mes a las 00:00.")}
              </li>
            </ul>

            <p class="text-slate-500 text-sm">
              {gettext(
                "En el Dashboard, al crear o editar un job, elige \"Cron\" como tipo y escribe la expresión en el campo (ej. 0 0 * * *). La hora se interpreta en el servidor; si necesitas otra zona horaria, configúrala en tu proyecto cuando esté disponible."
              )}
            </p>
          </div>
        </div>
      </section>

      <section id="project-token" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Proyecto, topics y token")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Consulta y actualiza el proyecto; gestiona el API Key. Todas las rutas requieren API Key."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/project</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext("Devuelve el proyecto: id, name, status, settings.")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/project" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                  PATCH
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/project</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Actualiza el proyecto. Body: name, settings (objeto). Respuesta: id, name, status."
                )}
              </p>
              <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X PATCH "<%= @base_url %>/api/v1/project" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '<%= "{\"name\":\"" %><%= gettext("Mi Proyecto") %><%= "\",\"settings\":{\"timezone\":\"Europe/Madrid\"}}" %>'</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/topics</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista los topics usados por tu proyecto (eventos activos). Útil para configurar filtros de webhooks. Respuesta: topics (array)."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/topics" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/token</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Devuelve el prefix del token actual (no el valor completo) y un mensaje de uso."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/token" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/token/regenerate</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Regenera el API Key. El token anterior deja de funcionar. Respuesta incluye token (valor completo) y message. Guarda el token; no se vuelve a mostrar."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/token/regenerate" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              <p class="text-amber-700 text-xs mt-3">
                {gettext("Tras regenerar, usa el nuevo token en las siguientes peticiones.")}
              </p>
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== FUNCIONES AVANZADAS ========== --%>
      <section id="simulate" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Simulador de webhooks")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Prueba qué webhooks coincidirían con un evento sin enviarlo realmente (dry-run)."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-indigo-500 bg-indigo-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "El simulador no crea eventos ni entregas. Solo evalúa las reglas de tus webhooks (topics, filters) y te muestra cuáles recibirían el payload."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/simulate</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Simula un evento. Body: cualquier JSON con topic opcional. Respuesta: simulation: true, matching_webhooks (cantidad) y results (array con detalle de cada webhook que coincide)."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/simulate" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"topic":"order.created","amount":150,"currency":"USD"}'</pre>
              <p class="text-slate-500 text-xs mt-3">{gettext("Respuesta ejemplo:")}</p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-1 font-mono"
                phx-no-curly-interpolation
              >{
  "simulation": true,
  "matching_webhooks": 2,
  "results": [
    {"webhook_id": "abc-123", "webhook_url": "https://my-server.com/hook", "matched_topics": ["order.created"]},
    {"webhook_id": "def-456", "webhook_url": "https://backup.com/hook", "matched_topics": ["*"]}
  ]
}</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="webhook-health" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Webhook Health")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Consulta el estado de salud de un webhook: tasa de éxito, último intento y código de respuesta."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/webhooks/:id/health
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Devuelve el health score del webhook: status (healthy, degraded, failing, unknown), success_rate (0-1), last_attempt_at y last_response_status."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/webhooks/WEBHOOK_ID/health" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
              <p class="text-slate-500 text-xs mt-3">{gettext("Respuesta ejemplo:")}</p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-1 font-mono"
                phx-no-curly-interpolation
              >{
  "webhook_id": "abc-123",
  "url": "https://my-server.com/hook",
  "health": {
    "status": "healthy",
    "success_rate": 0.98,
    "last_attempt_at": "2026-02-28T15:30:00Z",
    "last_response_status": 200
  }
}</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="dead-letters" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Dead Letter Queue")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Entregas que agotaron todos los reintentos. Puedes reintentar con payload modificado o marcarlas como resueltas."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-amber-500 bg-amber-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Las entregas van al DLQ cuando fallan todos los reintentos automáticos (1 min → 5 min → 15 min → 1 h). Desde aquí puedes reintentar manualmente o marcar como resueltas."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/dead-letters</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista dead letters. Query: resolved=true para ver las resueltas. Máximo 50 resultados."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/dead-letters" \
  -H "X-Api-Key: YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/dead-letters?resolved=true" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/dead-letters/:id</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Detalle de un dead letter: payload original, último error, código de respuesta, estado de resolución."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/dead-letters/DEAD_LETTER_ID" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/dead-letters/:id/retry
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Reintenta una entrega fallida. Opcionalmente envía un payload modificado en el body."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/dead-letters/DEAD_LETTER_ID/retry" \
  -H "X-Api-Key: YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/dead-letters/DEAD_LETTER_ID/retry" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"payload":{"topic":"order.created","fixed_field":"new_value"}}'</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                  PATCH
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/dead-letters/:id/resolve
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Marca un dead letter como resuelto sin reintentar. Respuesta: status: \"resolved\"."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X PATCH "<%= @base_url %>/api/v1/dead-letters/DEAD_LETTER_ID/resolve" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="replays" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Event Replay")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Re-envía eventos históricos a tus webhooks. Útil para recuperar datos o probar cambios en webhooks."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-indigo-500 bg-indigo-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Un replay toma eventos existentes (filtrados por topic, fecha, webhook) y crea nuevas entregas. El progreso se puede seguir en tiempo real desde el Dashboard."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/replays</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext("Lista todos los replays del proyecto con su estado y progreso.")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/replays" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/replays</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Crea un replay. Body opcional: topic, from_date (o from), to_date (o to), webhook_id. Sin filtros re-envía todos los eventos."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/replays" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"topic":"order.created","from":"2026-02-01T00:00:00Z","to":"2026-02-28T23:59:59Z"}'</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/replays" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"webhook_id":"WEBHOOK_ID"}'</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/replays/:id</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Detalle de un replay: estado (pending, running, completed, failed, cancelled), filtros, total de eventos y progreso."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/replays/REPLAY_ID" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                  DELETE
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/replays/:id</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Cancela un replay en progreso. Solo funciona si el replay está en estado pending o running."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X DELETE "<%= @base_url %>/api/v1/replays/REPLAY_ID" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== HERRAMIENTAS ========== --%>
      <section id="sandbox" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Sandbox (RequestBin)")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Crea URLs temporales para recibir y inspeccionar peticiones HTTP. Ideal para probar webhooks sin un servidor propio."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-emerald-500 bg-emerald-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Cada sandbox genera una URL única (ej: /sandbox/abc123) que acepta cualquier método HTTP. Todas las peticiones recibidas se guardan y se pueden inspeccionar en tiempo real desde el Dashboard."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/sandbox-endpoints
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext("Lista todos los sandbox endpoints del proyecto.")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/sandbox-endpoints" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/sandbox-endpoints
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Crea un sandbox endpoint. Body: name (requerido). Respuesta incluye slug y url para recibir peticiones."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/sandbox-endpoints" \
  -H "Content-Type: application/json" \
  -H "X-Api-Key: YOUR_API_KEY" \
  -d '{"name":"test-webhook-orders"}'</pre>
              <p class="text-slate-500 text-xs mt-3">{gettext("Respuesta ejemplo:")}</p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-1 font-mono"
                phx-no-curly-interpolation
              >{
  "id": "abc-123",
  "slug": "xk9m2p",
  "name": "test-webhook-orders",
  "url": "/sandbox/xk9m2p",
  "expires_at": "2026-03-01T00:00:00Z"
}</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                  DELETE
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/sandbox-endpoints/:id
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext("Elimina un sandbox endpoint y todas sus peticiones almacenadas.")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X DELETE "<%= @base_url %>/api/v1/sandbox-endpoints/ENDPOINT_ID" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/sandbox-endpoints/:id/requests
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista todas las peticiones recibidas en un sandbox: método, path, headers, body, query params e IP."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/sandbox-endpoints/ENDPOINT_ID/requests" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-violet-600 text-white">
                  ANY
                </span>

                <code class="font-mono text-slate-800 font-medium">/sandbox/:slug</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "URL pública para enviar peticiones de prueba. Acepta cualquier método HTTP (GET, POST, PUT, DELETE, etc.). No requiere autenticación."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/sandbox/xk9m2p" \
  -H "Content-Type: application/json" \
  -d '{"order_id":"12345","status":"completed"}'</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="analytics" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Analíticas")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Métricas y estadísticas del proyecto: eventos por día, entregas, topics populares y rendimiento por webhook."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/analytics/events-per-day
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Eventos creados por día. Query: days (1-90, default 30). Respuesta: array de {date, count}."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/analytics/events-per-day?days=7" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/analytics/deliveries-per-day
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Entregas realizadas por día. Query: days (1-90, default 30). Respuesta: array de {date, count}."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/analytics/deliveries-per-day?days=30" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/analytics/top-topics
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Topics más usados. Query: limit (1-50, default 10). Respuesta: array de {topic, count}."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/analytics/top-topics?limit=5" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">
                  /api/v1/analytics/webhook-stats
                </code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Estadísticas por webhook: total de entregas, exitosas, fallidas y tasa de éxito."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/analytics/webhook-stats" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
              <p class="text-slate-500 text-xs mt-3">{gettext("Respuesta ejemplo:")}</p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-1 font-mono"
                phx-no-curly-interpolation
              >{
  "data": [
    {"webhook_id": "abc-123", "url": "https://my-server.com/hook", "total_deliveries": 500, "successful": 490, "failed": 10, "success_rate": 0.98}
  ]
}</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="audit-log" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Audit Log")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Registro inmutable de todas las acciones realizadas en el proyecto: quién, qué, cuándo."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-slate-500 bg-slate-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "El audit log registra automáticamente: creación/eliminación de eventos, webhooks, sandbox endpoints, replays, regeneración de tokens y más. Los registros son inmutables y no se pueden modificar ni eliminar."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>
                <code class="font-mono text-slate-800 font-medium">/api/v1/audit-log</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Lista el audit log del proyecto. Query opcionales: action (ej: event.created, webhook.deleted), resource_type (ej: event, webhook). Ordenado por fecha descendente."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/audit-log" \
  -H "X-Api-Key: YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/audit-log?action=webhook.deleted" \
  -H "X-Api-Key: YOUR_API_KEY"</pre> <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-2 font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/v1/audit-log?resource_type=event" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="health" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Health Check")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Endpoint público para verificar el estado del sistema. No requiere autenticación."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/health</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Verifica el estado de la base de datos, el procesador de trabajos y la caché. Respuesta 200 si todo está bien o degradado, 503 si la BD está caída. Útil para load balancers y monitoring."
                )}
              </p>
              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Estados posibles: healthy (todo OK), degraded (funcionalidad principal OK pero servicios secundarios caídos), unhealthy (BD caída)."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/health"</pre>
              <p class="text-slate-500 text-xs mt-3">{gettext("Respuesta ejemplo:")}</p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto mt-1 font-mono"
                phx-no-curly-interpolation
              >{
  "status": "healthy",
  "timestamp": "2026-03-02T15:30:00Z"
}</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="status-page" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Página de estado")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Página pública que muestra el estado del sistema en tiempo real. No requiere autenticación."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-emerald-500 bg-emerald-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Accede a /status desde el navegador para ver el estado actual del sistema. La página se actualiza automáticamente y muestra verificaciones de los servicios principales."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("URL")}</h3>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              ><%= @base_url %>/status</pre>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2 mt-4">
                <li>{gettext("No requiere autenticación — accesible públicamente.")}</li>
                <li>{gettext("Se actualiza automáticamente cada 30 segundos.")}</li>
                <li>
                  {gettext("Muestra estado general: operativo, degradado o no disponible.")}
                </li>
                <li>
                  {gettext("Disponible en español e inglés según tu preferencia de idioma.")}
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="response-headers" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Headers de respuesta")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Headers útiles incluidos automáticamente en las respuestas de la API.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">X-Request-Id</h3>
              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Cada respuesta incluye un identificador único de request. Úsalo para rastrear problemas o al contactar soporte."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >X-Request-Id: f81d4fae-7dec-11d0-a765-00a0c91e6bf6</pre>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Rate Limiting")}
              </h3>
              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Las respuestas de la API incluyen headers que indican tu uso actual del rate limit:"
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">
                    X-RateLimit-Limit
                  </code>
                  — {gettext("Máximo de requests permitidos por minuto.")}
                </li>
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">
                    X-RateLimit-Remaining
                  </code>
                  — {gettext("Requests restantes en la ventana actual.")}
                </li>
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">
                    X-RateLimit-Reset
                  </code>
                  — {gettext("Timestamp Unix de cuando se reinicia la ventana.")}
                </li>
                <li>
                  <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">Retry-After</code>
                  — {gettext("Segundos hasta el reinicio (solo en respuestas 429).")}
                </li>
              </ul>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono mt-4"
                phx-no-curly-interpolation
              ># <%= gettext("Ejemplo de headers en una respuesta") %>
X-RateLimit-Limit: 500
X-RateLimit-Remaining: 498
X-RateLimit-Reset: 1709750400</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="openapi" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("OpenAPI / Swagger")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Documentación interactiva auto-generada de toda la API. Prueba endpoints directamente desde el navegador."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-indigo-500 bg-indigo-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "La especificación OpenAPI 3.x se genera automáticamente desde el código. Incluye todos los endpoints, parámetros, schemas y ejemplos."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/swaggerui</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Interfaz Swagger UI interactiva. Abre en el navegador para explorar y probar todos los endpoints."
                )}
              </p>

              <a
                href="/api/swaggerui"
                target="_blank"
                class="inline-flex items-center px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition"
              >
                {gettext("Abrir Swagger UI")} →
              </a>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                  GET
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/openapi</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "Especificación OpenAPI en formato JSON. Útil para generar clientes SDK automáticamente."
                )}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X GET "<%= @base_url %>/api/openapi"</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="usage" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Formas de usar la aplicación")}
            </h2>
          </div>

          <div class="p-8">
            <ul class="text-slate-700 space-y-4">
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  1
                </span>
                <span>
                  <strong>{gettext("Web:")}</strong> {gettext(
                    "registro e inicio de sesión; Dashboard para proyecto, token, eventos y webhooks; enviar eventos de prueba desde el dashboard."
                  )}
                </span>
              </li>

              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  2
                </span>
                <span>
                  <strong>{gettext("API con API Key:")}</strong> {gettext(
                    "desde cualquier backend o frontend (SPA, móvil, otro dominio gracias a CORS) usa la API Key para enviar eventos, gestionar webhooks, listar deliveries y jobs."
                  )}
                </span>
              </li>

              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  3
                </span>
                <span>
                  <strong>{gettext("API de auth (JWT):")}</strong> {gettext(
                    "para tu app propia (móvil o SPA), usa /auth/register, /auth/login y /auth/refresh para mantener sesión con JWT."
                  )}
                </span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section id="status-codes" class="mb-8 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Códigos de respuesta")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Códigos HTTP que devuelve la API.")}
            </p>
          </div>

          <div class="p-8">
            <ul class="text-slate-700 space-y-2">
              <li><strong>200</strong> {gettext("OK (éxito)")}</li>

              <li><strong>201</strong> {gettext("Created (recurso creado)")}</li>

              <li><strong>202</strong> {gettext("Accepted (evento aceptado)")}</li>

              <li>
                <strong>401</strong> {gettext("No autorizado (API Key o JWT inválido o faltante)")}
              </li>

              <li><strong>404</strong> {gettext("Recurso no encontrado")}</li>

              <li>
                <strong>422</strong> {gettext(
                  "Validación fallida (body o parámetros incorrectos)"
                )}
              </li>

              <li><strong>403</strong> {gettext("Prohibido (scope insuficiente)")}</li>
            </ul>
          </div>
        </div>
      </section>
      <%!-- ========== Phase 5: Expansion ========== --%>
      <section id="multi-project" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Multi-proyecto")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Gestiona múltiples proyectos desde una sola cuenta. Cada proyecto tiene sus propios webhooks, eventos y API keys."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Autenticación: JWT (Bearer token). Las rutas de proyecto usan el pipeline de auth JWT, no API Key."
              )}
            </p>

            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/projects</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Lista todos tus proyectos (propios + donde eres miembro).")}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/projects" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/projects</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Crea un nuevo proyecto. El primer proyecto se marca como default automáticamente."
                  )}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/projects" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -d '{"name":"Mi segundo proyecto"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/projects/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Detalle de un proyecto. Respuesta: id, name, status, settings, is_default."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/projects/PROJECT_ID" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    PATCH
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/projects/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Actualiza el proyecto. Body: name, settings (objeto). Respuesta: id, name, status."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X PATCH "<%= @base_url %>/api/v1/projects/PROJECT_ID" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -d '{"name":"Proyecto renombrado"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    DELETE
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/projects/:id</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Desactiva el proyecto (soft delete). No se puede eliminar el proyecto default."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X DELETE "<%= @base_url %>/api/v1/projects/PROJECT_ID" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    PATCH
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/projects/:id/default
                  </code>
                </div>

                <p class="text-slate-700 text-sm">
                  {gettext("Establece un proyecto como default. El dashboard lo cargará primero.")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono mt-3">curl -X PATCH "<%= @base_url %>/api/v1/projects/PROJECT_ID/default" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="api-key-scopes" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Scopes de API Key")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Limita los permisos de cada API Key con scopes granulares.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Por defecto, las API Keys tienen scope '*' (acceso total). Puedes restringirlas a operaciones específicas."
              )}
            </p>

            <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900 text-sm mb-3">
                {gettext("Scopes disponibles")}
              </h3>

              <div class="grid sm:grid-cols-2 gap-2 text-sm">
                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    *
                  </code>
                  — {gettext("Acceso total")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    events:read
                  </code>
                  — {gettext("Leer eventos")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    events:write
                  </code>
                  — {gettext("Crear/eliminar eventos")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    webhooks:read
                  </code>
                  — {gettext("Leer webhooks")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    webhooks:write
                  </code>
                  — {gettext("CRUD webhooks")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    jobs:read
                  </code>
                  — {gettext("Leer jobs")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    jobs:write
                  </code>
                  — {gettext("CRUD jobs")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    deliveries:read
                  </code>
                  — {gettext("Leer entregas")}
                </div>

                <div>
                  <code class="bg-white px-2 py-1 rounded border border-slate-200 text-xs font-mono">
                    deliveries:retry
                  </code>
                  — {gettext("Reintentar entregas")}
                </div>
              </div>
            </div>

            <p class="text-slate-600 text-sm">
              {gettext("Si una API Key no tiene el scope requerido, recibirá un 403 Forbidden.")}
            </p>
          </div>
        </div>
      </section>

      <section id="event-schemas" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Event Schemas")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Valida los payloads de eventos con JSON Schema antes de aceptarlos.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "La validación es opt-in: si no hay schema para un topic, el evento pasa sin validar. Si hay schema y el payload no cumple, se rechaza con 422."
              )}
            </p>

            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/event-schemas</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Lista los schemas del proyecto. Respuesta: schemas (array).")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/event-schemas" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/event-schemas</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Crea un schema para un topic.")}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/event-schemas" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"topic":"order.created","schema":{"type":"object","required":["amount","currency"],"properties":{"amount":{"type":"number","minimum":0},"currency":{"type":"string","minLength":3}}}}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/event-schemas/:id
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Detalle de un schema. Respuesta: id, topic, schema, version, status.")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/event-schemas/SCHEMA_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    DELETE
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/event-schemas/:id
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Desactiva el schema. Respuesta 200: status: \"inactive\".")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X DELETE "<%= @base_url %>/api/v1/event-schemas/SCHEMA_ID" \
  -H "Authorization: Bearer YOUR_API_KEY"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/event-schemas/validate
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Validación dry-run: prueba si un payload cumpliría el schema sin enviar el evento."
                  )}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/event-schemas/validate" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"topic":"order.created","payload":{"amount":150,"currency":"USD"}}'</pre>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="delayed-events" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Eventos diferidos")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Programa eventos para que se entreguen en el futuro.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Incluye el campo 'deliver_at' (ISO 8601) al enviar un evento. La entrega se ejecutará cuando llegue la hora."
              )}
            </p>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                  POST
                </span>

                <code class="font-mono text-slate-800 font-medium">/api/v1/events</code>
              </div>

              <p class="text-slate-700 text-sm mb-3">
                {gettext(
                  "El evento se crea inmediatamente (202 Accepted) pero las entregas a webhooks se retrasan hasta deliver_at."
                )}
              </p>

              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                {gettext("Ejemplo")}
              </p>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >curl -X POST "<%= @base_url %>/api/v1/events" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"topic":"reminder.send","message":"Tu cita es mañana","deliver_at":"2026-03-02T10:00:00Z"}'</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="realtime-stream" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Streaming en tiempo real")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Recibe eventos en tiempo real vía SSE o WebSocket.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>

                  <code class="font-mono text-slate-800 font-medium">/api/v1/stream</code>
                  <span class="text-xs text-slate-500">
                    ({gettext("Server-Sent Events (SSE)")})
                  </span>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Conexión HTTP unidireccional. Ideal para dashboards y monitoreo.")}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -N "<%= @base_url %>/api/v1/stream" \
  -H "X-Api-Key: YOUR_API_KEY"</pre>
                <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 mt-3 text-sm">
                  <p class="font-medium text-slate-800 mb-2">{gettext("Formato de mensajes:")}</p>

                  <ul class="text-slate-600 space-y-1 list-disc list-inside">
                    <li>
                      <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono text-xs">
                        event.created
                      </code>
                      — {gettext("Nuevo evento recibido")}
                    </li>

                    <li>
                      <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono text-xs">
                        delivery.updated
                      </code>
                      — {gettext("Estado de entrega actualizado")}
                    </li>

                    <li>
                      <code class="bg-white px-1.5 py-0.5 rounded border border-slate-200 font-mono text-xs">
                        keepalive
                      </code>
                      — {gettext("Cada 30 segundos")}
                    </li>
                  </ul>
                </div>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    WS
                  </span>

                  <code class="font-mono text-slate-800 font-medium">/ws</code>
                  <span class="text-xs text-slate-500">({gettext("WebSocket")})</span>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Conexión bidireccional vía Phoenix Channels. Autenticación con API Key."
                  )}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo (JavaScript)")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >import {Socket} from "phoenix"
let socket = new Socket("/ws", {params: {token: "YOUR_API_KEY"}})
socket.connect()
let channel = socket.channel("events:PROJECT_ID")
channel.join()
channel.on("event:created", payload => console.log(payload))
channel.on("delivery:updated", payload => console.log(payload))</pre>
              </div>
            </div>

            <p class="text-slate-600 text-sm">
              {gettext("Requiere scope 'events:read' en la API Key.")}
            </p>
          </div>
        </div>
      </section>

      <section id="teams" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Equipos / Colaboradores")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Invita usuarios a tus proyectos con roles diferenciados.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Autenticación: JWT. Roles disponibles: owner (dueño, acceso total), editor (lectura/escritura), viewer (solo lectura)."
              )}
            </p>

            <div class="space-y-8">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/projects/:project_id/members
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista miembros del proyecto. Respuesta: members (array con id, user_id, role, status)."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/projects/PROJECT_ID/members" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/projects/:project_id/members
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Invita a un usuario al proyecto. Requiere rol owner o editor. Puedes usar user_id o email."
                  )}
                </p>

                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">
                  {gettext("Ejemplo")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/projects/PROJECT_ID/members" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -d '{"user_id":"UUID_DEL_USUARIO","role":"editor"}'

# <%= gettext("O por email") %>:
curl -X POST "<%= @base_url %>/api/v1/projects/PROJECT_ID/members" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -d '{"email":"usuario@example.com","role":"viewer"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    PATCH
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/projects/:project_id/members/:id
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Actualiza el rol de un miembro. Body: role (editor, viewer).")}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X PATCH "<%= @base_url %>/api/v1/projects/PROJECT_ID/members/MEMBER_ID" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -d '{"role":"viewer"}'</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    DELETE
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/projects/:project_id/members/:id
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext("Remueve un miembro del proyecto. No se puede remover al owner.")}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X DELETE "<%= @base_url %>/api/v1/projects/PROJECT_ID/members/MEMBER_ID" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>
            </div>

            <h3 class="text-lg font-semibold text-slate-800 mt-6 mb-3">
              {gettext("Invitaciones")}
            </h3>

            <div class="space-y-4">
              <div class="border border-slate-200 rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 rounded text-xs font-bold bg-blue-100 text-blue-700">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/invitations/pending
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista las invitaciones pendientes del usuario autenticado. Devuelve id, role, project_id y project_name."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X GET "<%= @base_url %>/api/v1/invitations/pending" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="border border-slate-200 rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 rounded text-xs font-bold bg-emerald-100 text-emerald-700">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/invitations/:id/accept
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Acepta una invitación pendiente. Solo el usuario invitado puede aceptarla. Cambia el status a 'active'."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X POST "<%= @base_url %>/api/v1/invitations/MEMBER_ID/accept" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>

              <div class="border border-slate-200 rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 rounded text-xs font-bold bg-emerald-100 text-emerald-700">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/invitations/:id/reject
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Rechaza una invitación pendiente. Solo el usuario invitado puede rechazarla. Cambia el status a 'removed'."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl -X POST "<%= @base_url %>/api/v1/invitations/MEMBER_ID/reject" \
  -H "Authorization: Bearer YOUR_JWT_TOKEN"</pre>
              </div>
            </div>

            <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800 mt-4">
              {gettext(
                "En el dashboard, busca la sección 'Equipo'. Puedes invitar por email, cambiar roles y remover miembros desde la interfaz. Las invitaciones pendientes aparecen como banner y en las notificaciones."
              )}
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== CURSOR PAGINATION ========== --%>
      <section id="cursor-pagination" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Paginación cursor")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Paginación eficiente basada en cursor para listas grandes de eventos y entregas."
              )}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "En lugar de offset/page, usa cursores para recorrer resultados de forma estable y performante. Los endpoints GET /events y GET /deliveries soportan paginación cursor."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/events?limit=20&cursor=CURSOR
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Parámetros: limit (máx 100, default 20), cursor (opaque string del campo next_cursor). Respuesta: data (array), has_next (boolean), next_cursor (string|null)."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl "<%= @base_url %>/api/v1/events?limit=10" \
  -H "X-API-Key: YOUR_API_KEY"

# Siguiente página:
curl "<%= @base_url %>/api/v1/events?limit=10&cursor=NEXT_CURSOR_VALUE" \
  -H "X-API-Key: YOUR_API_KEY"</pre>
              </div>
            </div>

            <div class="rounded-xl bg-blue-50 border border-blue-200 p-4 text-sm text-blue-800">
              {gettext(
                "El cursor es un valor opaco. No lo modifiques; simplemente pasa el next_cursor de la respuesta anterior para obtener la página siguiente."
              )}
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== BATCH EVENTS ========== --%>
      <section id="batch-events" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Batch Events")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Agrupa múltiples eventos en una sola entrega para reducir llamadas HTTP.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Configura batch_config en tu webhook para acumular eventos y enviarlos juntos. El sistema agrupa automáticamente los eventos y los entrega cuando se cumple la ventana de tiempo o el tamaño máximo."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-indigo-600 text-white">
                    POST
                  </span>
                  <code class="font-mono text-slate-800 font-medium">/api/v1/webhooks</code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Crea un webhook con batch_config habilitado. Campos: enabled (bool), window_seconds (int, ventana de acumulación), max_batch_size (int, máximo de eventos por lote)."
                  )}
                </p>
                <pre
                  class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                  phx-no-curly-interpolation
                >curl -X POST "<%= @base_url %>/api/v1/webhooks" \
  -H "Content-Type: application/json" \
  -H "X-API-Key: YOUR_API_KEY" \
  -d '{"url":"https://example.com/batch","topics":["order.*"],
  "batch_config":{"enabled":true,"window_seconds":60,"max_batch_size":50}}'</pre>
              </div>
            </div>

            <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
              {gettext(
                "Los eventos se acumulan en una cola interna. Cada minuto, el worker verifica si la ventana expiró o se alcanzó el tamaño máximo y envía el lote completo."
              )}
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== EXPORT CSV/JSON ========== --%>
      <section id="export" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Exportar datos")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Exporta eventos, entregas, jobs y audit log en formato CSV o JSON.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Descarga tus datos para análisis externo. Todos los endpoints de exportación soportan el parámetro format=csv o format=json (default)."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/export/events?format=csv
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Exporta eventos. Formatos: csv, json. Parámetros opcionales: days (default 30)."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl "<%= @base_url %>/api/v1/export/events?format=csv&days=7" \
  -H "X-API-Key: YOUR_API_KEY" -o events.csv</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/export/deliveries | jobs | audit-log
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Mismos parámetros para entregas, jobs y audit log. Todos soportan format=csv|json y days=N."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl "<%= @base_url %>/api/v1/export/deliveries?format=json&days=14" \
  -H "X-API-Key: YOUR_API_KEY"
curl "<%= @base_url %>/api/v1/export/audit-log?format=csv" \
  -H "X-API-Key: YOUR_API_KEY" -o audit.csv</pre>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /export/events | deliveries | jobs | audit-log
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Rutas de exportación para el navegador (Dashboard). Usan autenticación de sesión, sin API Key. Los mismos parámetros format=csv|json aplican."
                  )}
                </p>
                <div class="rounded-lg bg-blue-50 border border-blue-200 p-3 text-sm text-blue-800">
                  {gettext(
                    "Estas rutas son usadas automáticamente por los botones de exportación del Dashboard. No requieren API Key."
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== WEBHOOK TEMPLATES ========== --%>
      <section id="webhook-templates" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Plantillas webhook")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Configuraciones predefinidas para integraciones populares.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Usa plantillas para crear webhooks preconfigurados para Slack, Discord, Telegram y más. Cada plantilla incluye headers, body_config y transformaciones listas para usar."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/webhooks/templates
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Lista las plantillas disponibles: slack, discord, telegram, generic_json, custom. Cada una incluye name, description, headers y body_config."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl "<%= @base_url %>/api/v1/webhooks/templates" \
  -H "X-API-Key: YOUR_API_KEY"</pre>
              </div>
            </div>

            <div class="rounded-xl bg-blue-50 border border-blue-200 p-4 text-sm text-blue-800">
              {gettext(
                "Usa los campos de la plantilla al crear un webhook. Por ejemplo, para Slack usa los headers y body_config de la plantilla 'slack' al hacer POST /api/v1/webhooks."
              )}
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== CRON PREVIEW ========== --%>
      <section id="cron-preview" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Cron preview")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Previsualiza las próximas ejecuciones de una expresión cron.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Valida y previsualiza cuándo se ejecutará tu job cron antes de crearlo. Útil para verificar expresiones complejas."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    GET
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    /api/v1/jobs/cron-preview?expression=*/5+*+*+*+*&count=5
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Parámetros: expression (cron expression), count (número de ejecuciones a mostrar, default 5). Respuesta: expression, next_executions (array de timestamps)."
                  )}
                </p>
                <pre class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono">curl "<%= @base_url %>/api/v1/jobs/cron-preview?expression=0+9+*+*+1-5&count=3" \
  -H "X-API-Key: YOUR_API_KEY"</pre>
              </div>
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== IP ALLOWLIST ========== --%>
      <section id="ip-allowlist" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("IP Allowlist")}</h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Restringe el acceso a tu API key por dirección IP.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Añade una capa extra de seguridad permitiendo que tu API key solo funcione desde IPs específicas. Si la lista está vacía, cualquier IP puede usar la key."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Configura allowed_ips al crear o regenerar tu API key desde el dashboard. Las IPs se verifican usando el header X-Forwarded-For (load balancers/proxies) o la IP de conexión directa."
                  )}
                </p>

                <p class="text-slate-700 text-sm">
                  {gettext(
                    "Ejemplo de IPs permitidas: [\"203.0.113.10\", \"198.51.100.0/24\"]. Si una petición llega desde una IP no autorizada, recibirá un 403 Forbidden."
                  )}
                </p>
              </div>
            </div>

            <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
              {gettext(
                "Asegúrate de incluir tu IP actual antes de activar el allowlist, de lo contrario perderás acceso. Puedes gestionar las IPs desde el panel del dashboard."
              )}
            </div>
          </div>
        </div>
      </section>

      <%!-- ═══════════════════════════════════════════════════ --%>
      <%!-- CUENTA Y PLATAFORMA                                --%>
      <%!-- ═══════════════════════════════════════════════════ --%>

      <section id="account-management" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Gestión de cuenta")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Perfil, seguridad y configuración de tu cuenta de usuario.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Desde la página de cuenta (/account) puedes gestionar todos los aspectos de tu perfil y seguridad. Todas las acciones sensibles requieren confirmar tu contraseña actual."
              )}
            </p>

            <div class="space-y-8">
              <%!-- Verificar email --%>
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-600 text-white">
                    {gettext("Verificación")}
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    {gettext("Verificar email")}
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Al registrarte se envía un correo de verificación a tu dirección de email. Puedes reenviar el enlace desde /account. El enlace de verificación expira en 7 días."
                  )}
                </p>

                <div class="rounded-lg bg-indigo-50 border border-indigo-200 p-3 text-sm text-indigo-800">
                  {gettext(
                    "Rate limit: solo puedes solicitar un correo de verificación cada 5 minutos para evitar spam."
                  )}
                </div>
              </div>

              <%!-- Cambiar email --%>
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    {gettext("Modificar")}
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    {gettext("Cambiar email")}
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Puedes cambiar tu dirección de email desde /account. Debes confirmar tu contraseña actual y el nuevo email debe ser único (no estar registrado por otro usuario)."
                  )}
                </p>
              </div>

              <%!-- Cambiar contraseña --%>
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-600 text-white">
                    {gettext("Modificar")}
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    {gettext("Cambiar contraseña")}
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Cambia tu contraseña desde /account. Debes ingresar tu contraseña actual y la nueva contraseña (mínimo 8 caracteres con mayúsculas, minúsculas y números)."
                  )}
                </p>
              </div>

              <%!-- Eliminar cuenta --%>
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
                    {gettext("Peligro")}
                  </span>
                  <code class="font-mono text-slate-800 font-medium">
                    {gettext("Eliminar cuenta")}
                  </code>
                </div>

                <p class="text-slate-700 text-sm mb-3">
                  {gettext(
                    "Puedes eliminar permanentemente tu cuenta desde /account. Esta acción requiere confirmar tu contraseña y es irreversible: se eliminan todos tus datos, proyectos, webhooks y eventos asociados."
                  )}
                </p>

                <div class="rounded-lg bg-red-50 border border-red-200 p-3 text-sm text-red-800">
                  {gettext(
                    "Advertencia: la eliminación de cuenta es permanente. No se puede deshacer. Asegúrate de exportar tus datos antes si los necesitas."
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="password-recovery" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Recuperar contraseña")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Flujo completo para restablecer tu contraseña si la olvidaste.")}
            </p>
          </div>

          <div class="p-8 space-y-5">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "Si olvidaste tu contraseña puedes restablecerla desde la página de login. El proceso es seguro y protegido con rate limiting."
              )}
            </p>

            <ul class="text-slate-700 space-y-4">
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  1
                </span>
                <span>
                  <strong>{gettext("Solicitar enlace:")}</strong>
                  {gettext(
                    "Ve a /forgot-password e ingresa tu email registrado. Recibirás un correo con un enlace para restablecer tu contraseña."
                  )}
                </span>
              </li>

              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  2
                </span>
                <span>
                  <strong>{gettext("Revisar correo:")}</strong>
                  {gettext(
                    "Revisa tu bandeja de entrada (y la carpeta de spam). El correo llega en el idioma que tengas seleccionado en la plataforma."
                  )}
                </span>
              </li>

              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  3
                </span>
                <span>
                  <strong>{gettext("Crear nueva contraseña:")}</strong>
                  {gettext(
                    "Haz clic en el enlace del correo. Se abrirá un formulario donde puedes ingresar tu nueva contraseña (mínimo 8 caracteres)."
                  )}
                </span>
              </li>

              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                  4
                </span>
                <span>
                  <strong>{gettext("Iniciar sesión:")}</strong>
                  {gettext(
                    "Una vez restablecida, serás redirigido al login para ingresar con tu nueva contraseña."
                  )}
                </span>
              </li>
            </ul>

            <div class="space-y-4 mt-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                  {gettext("Seguridad del flujo")}
                </p>

                <ul class="text-slate-700 text-sm space-y-2">
                  <li>
                    {gettext("El enlace de restablecimiento expira en 60 minutos.")}
                  </li>
                  <li>
                    {gettext("Solo se puede solicitar un correo de recuperación cada 5 minutos.")}
                  </li>
                  <li>
                    {gettext(
                      "El mensaje siempre dice \"si tu correo está registrado\" para no revelar si un email existe en el sistema."
                    )}
                  </li>
                  <li>
                    {gettext("Los tokens se eliminan automáticamente tras usarse o expirar.")}
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="dashboard-overview" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Dashboard")}
            </h2>

            <p class="text-slate-600 mt-1 text-sm">
              {gettext("Panel visual para gestionar tu plataforma de webhooks y eventos.")}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <p class="text-slate-700 leading-relaxed">
              {gettext(
                "El dashboard (/platform) es la interfaz principal donde gestionas todo sin necesidad de usar la API. Todas las funcionalidades de la API están disponibles visualmente."
              )}
            </p>

            <div class="space-y-4">
              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">
                  {gettext("Pestañas disponibles")}
                </p>

                <ul class="text-slate-700 text-sm space-y-3">
                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Eventos")}
                    </span>
                    <span>
                      {gettext(
                        "Envía eventos de prueba, lista todos los eventos con filtros por topic, y visualiza el payload de cada uno."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Webhooks")}
                    </span>
                    <span>
                      {gettext(
                        "Crea, edita y elimina webhooks. Configura URL destino, topics, secreto HMAC, reintentos, batch y filtros."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Entregas")}
                    </span>
                    <span>
                      {gettext(
                        "Monitorea cada intento de entrega: status HTTP, duración, headers de respuesta. Reintenta entregas fallidas."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Jobs")}
                    </span>
                    <span>
                      {gettext(
                        "Programa tareas recurrentes (cron) o puntuales. Ejecutan webhooks, HTTP requests o eventos en el schedule definido."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Dead Letters")}
                    </span>
                    <span>
                      {gettext(
                        "Cola de entregas que fallaron tras todos los reintentos. Puedes reintentar o marcar como resueltas."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Replays")}
                    </span>
                    <span>
                      {gettext(
                        "Re-envía eventos históricos a webhooks. Útil para recuperar datos tras un downtime o migrar a un nuevo endpoint."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Schemas")}
                    </span>
                    <span>
                      {gettext(
                        "Define JSON Schemas para validar el payload de tus eventos. Los eventos que no cumplan el schema serán rechazados."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Sandbox")}
                    </span>
                    <span>
                      {gettext(
                        "Crea endpoints de prueba para recibir webhooks sin necesidad de un servidor propio. Inspecciona cada petición recibida."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Analíticas")}
                    </span>
                    <span>
                      {gettext(
                        "Gráficos de eventos por día, entregas por día, top topics y estadísticas por webhook."
                      )}
                    </span>
                  </li>

                  <li class="flex gap-3">
                    <span class="font-semibold text-indigo-600 min-w-[100px]">
                      {gettext("Audit Log")}
                    </span>
                    <span>
                      {gettext(
                        "Registro inmutable de todas las acciones realizadas en tu proyecto: quién hizo qué y cuándo."
                      )}
                    </span>
                  </li>
                </ul>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">
                  {gettext("Funciones adicionales del dashboard")}
                </p>

                <ul class="text-slate-700 text-sm space-y-2">
                  <li>
                    <strong>{gettext("Exportar datos:")}</strong>
                    {gettext(
                      "Descarga eventos, entregas, jobs o audit log en formato CSV o JSON directamente desde el navegador."
                    )}
                  </li>
                  <li>
                    <strong>{gettext("Notificaciones:")}</strong>
                    {gettext(
                      "Campana de notificaciones con alertas en tiempo real sobre invitaciones a proyectos y eventos del sistema."
                    )}
                  </li>
                  <li>
                    <strong>{gettext("Multi-proyecto:")}</strong>
                    {gettext(
                      "Cambia entre proyectos desde el selector del dashboard. Cada proyecto tiene sus propios webhooks, eventos y configuración."
                    )}
                  </li>
                  <li>
                    <strong>{gettext("Idioma:")}</strong>
                    {gettext(
                      "Cambia entre español e inglés en cualquier momento. La interfaz y los correos se adaptan al idioma seleccionado."
                    )}
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section id="account-lockout" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Bloqueo de cuenta")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Protección contra ataques de fuerza bruta. Tras múltiples intentos fallidos de login, la cuenta se bloquea temporalmente."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-amber-500 bg-amber-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Después de varios intentos fallidos consecutivos, la cuenta se bloquea temporalmente. El bloqueo se desactiva automáticamente al expirar. Cada intento fallido y cada bloqueo se registra en el audit log."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Comportamiento")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext(
                    "Contraseña incorrecta: se incrementa el contador de intentos fallidos."
                  )}
                </li>
                <li>
                  {gettext("Múltiples intentos fallidos: la cuenta se bloquea temporalmente.")}
                </li>
                <li>
                  {gettext(
                    "Login durante bloqueo: respuesta HTTP 423 (API) o mensaje flash (web)."
                  )}
                </li>
                <li>
                  {gettext(
                    "Bloqueo expirado: se desbloquea automáticamente en el siguiente intento."
                  )}
                </li>
                <li>{gettext("Login exitoso: el contador se reinicia a 0.")}</li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Respuesta API (cuenta bloqueada)")}
              </h3>
              <pre
                class="bg-slate-800 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto font-mono"
                phx-no-curly-interpolation
              >HTTP 423 Locked
{
  "error": "Account temporarily locked due to multiple failed login attempts. Try again later."
}</pre>
            </div>
          </div>
        </div>
      </section>

      <section id="session-timeout" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Timeout de sesión")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Las sesiones web se invalidan automáticamente después de un período de inactividad para proteger cuentas desatendidas."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Después de un período de inactividad, la sesión web expira automáticamente. El usuario es redirigido a la página de login con un mensaje informativo. Las sesiones de API (JWT) tienen su propia expiración independiente."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Comportamiento")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext("Cada request HTTP actualiza el timestamp de última actividad.")}
                </li>
                <li>
                  {gettext("Si pasa el período de inactividad máximo, la sesión se invalida.")}
                </li>
                <li>
                  {gettext(
                    "Aplica a sesiones web (browser). Tokens JWT de API tienen su propia expiración independiente."
                  )}
                </li>
                <li>{gettext("LiveView también verifica el timeout al montar componentes.")}</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="mfa-totp" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("MFA / TOTP")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Autenticación multifactor con códigos TOTP de 6 dígitos. Compatible con Google Authenticator, Authy, y cualquier app TOTP."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <%!-- Overview --%>
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "MFA agrega una capa extra de seguridad. Después de ingresar tu contraseña, necesitas un código temporal de tu aplicación de autenticación. También se generan códigos de recuperación de un solo uso."
                )}
              </p>
            </div>

            <%!-- Web flow --%>
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Flujo web (browser)")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext(
                    "Activar: Cuenta → Autenticación de dos factores → Escanear QR → Confirmar código"
                  )}
                </li>
                <li>
                  {gettext(
                    "Login: Email + contraseña → si MFA activo, se pide código de 6 dígitos → Dashboard"
                  )}
                </li>
                <li>
                  {gettext(
                    "Recuperación: Si no tienes acceso a tu app, usa un código de recuperación"
                  )}
                </li>
                <li>
                  {gettext("Desactivar: Cuenta → Desactivar MFA → Confirmar con contraseña")}
                </li>
              </ul>
            </div>

            <%!-- API flow --%>
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("Flujo API")}</h3>
              <p class="text-slate-600 text-sm mb-4">
                {gettext(
                  "Si el usuario tiene MFA activo, el login devuelve un token temporal de verificación."
                )}
              </p>

              <%!-- Step 1: Login --%>
              <div class="mb-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold">
                    1
                  </span>
                  <h4 class="font-medium text-slate-800 text-sm">POST /api/v1/auth/login</h4>
                </div>
                <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                  <pre class="text-sm text-slate-100 font-mono whitespace-pre"><code>curl -X POST <%= gettext("https://tu-dominio.com") %>/api/v1/auth/login \
  -H "Content-Type: application/json" \
  -d '<%= ~s({"email": "user@example.com", "password": "secreto123"}) %>'

# <%= gettext("Respuesta si MFA está activo") %>:
<%= ~s({"mfa_required": true, "mfa_token": "eyJ..."}) %></code></pre>
                </div>
              </div>

              <%!-- Step 2: Verify MFA --%>
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold">
                    2
                  </span>
                  <h4 class="font-medium text-slate-800 text-sm">POST /api/v1/auth/mfa/verify</h4>
                </div>
                <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                  <pre class="text-sm text-slate-100 font-mono whitespace-pre"><code>curl -X POST <%= gettext("https://tu-dominio.com") %>/api/v1/auth/mfa/verify \
  -H "Content-Type: application/json" \
  -d '<%= ~s({"mfa_token": "eyJ...", "code": "123456"}) %>'

# <%= gettext("Respuesta exitosa") %>:
<%= ~s({"user": {"id": "...", "email": "..."}, "token": "eyJ..."}) %></code></pre>
                </div>
              </div>
            </div>

            <%!-- Security details --%>
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Seguridad del flujo")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("El token MFA tiene un período de validez corto.")}</li>
                <li>
                  {gettext(
                    "Los códigos de recuperación se almacenan con hash seguro (nunca en texto plano)."
                  )}
                </li>
                <li>
                  {gettext(
                    "El secreto TOTP se cifra en la base de datos con cifrado estándar de la industria."
                  )}
                </li>
                <li>
                  {gettext("Cada código de recuperación se consume al usarlo (un solo uso).")}
                </li>
                <li>{gettext("Desactivar MFA requiere la contraseña actual.")}</li>
                <li>{gettext("Todos los eventos MFA se registran en el audit log.")}</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="backups" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Backups automáticos")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Backups automatizados de la base de datos. Ejecutados periódicamente de forma automática."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Los backups se generan automáticamente de forma periódica. Se comprimen y almacenan de forma segura con redundancia. Los backups antiguos se eliminan automáticamente según la política de retención configurada."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Configuración")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("Habilitado por defecto en todos los entornos.")}</li>
                <li>{gettext("Ejecución periódica automatizada.")}</li>
                <li>
                  {gettext(
                    "Retención configurable (los backups antiguos se eliminan automáticamente)."
                  )}
                </li>
                <li>{gettext("Almacenamiento seguro con redundancia en producción.")}</li>
                <li>{gettext("Los backups están cifrados en reposo y en tránsito.")}</li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Almacenamiento en la nube")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "En producción, los backups se transfieren automáticamente a almacenamiento remoto seguro. Si la transferencia falla, el archivo se conserva localmente como respaldo."
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext("Los backups en la nube están cifrados en reposo y en tránsito.")}
                </li>
                <li>
                  {gettext(
                    "La política de retención aplica tanto al almacenamiento remoto como al local."
                  )}
                </li>
                <li>
                  {gettext(
                    "Sin almacenamiento remoto configurado, los backups se guardan solo en disco local."
                  )}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("Health check")}</h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext("El endpoint /health incluye el estado del último backup.")}
              </p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre class="text-sm text-slate-100 font-mono whitespace-pre"><code>curl <%= gettext("https://tu-dominio.com") %>/health

# <%= gettext("Respuesta incluye") %>:
<%= ~s["backup": "ok (streamflix_20260303_020000.sql.gz)"] %></code></pre>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("Auditoría")}</h3>
              <p class="text-slate-600 text-sm">
                {gettext(
                  "Cada backup exitoso o fallido se registra automáticamente en el audit log del sistema."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>
      <%!-- ========== PROTECCIÓN DE DATOS (GDPR) ========== --%>
      <section id="data-protection" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Protección de datos")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Derechos GDPR/RGPD: exportación de datos personales, gestión de consentimientos y derecho de supresión."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Cumplimos con el Reglamento General de Protección de Datos (RGPD). Los usuarios pueden exportar sus datos, gestionar consentimientos y eliminar su cuenta completa en cualquier momento."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Exportar datos personales (DSAR)")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Descarga una copia completa de todos tus datos personales en formato JSON. Incluye perfil, proyectos, webhooks, conteos de eventos/entregas, jobs, notificaciones, registros de auditoría y consentimientos."
                )}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">
                {gettext("Desde el navegador")}:
              </p>
              <p class="text-slate-600 text-sm mb-3">
                {gettext("Sección «Cuenta» → «Protección de datos» → «Exportar datos»")}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">{gettext("Vía API")}:</p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre class="text-sm text-slate-100 font-mono whitespace-pre"><code># GET /api/v1/me/data
curl -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  <%= gettext("https://tu-dominio.com") %>/api/v1/me/data</code></pre>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Consentimientos")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Al registrarte se otorgan consentimientos para: Términos de uso, Política de privacidad y Procesamiento de datos. Puedes consultar y revocar cada consentimiento desde la sección «Cuenta»."
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("Cada consentimiento registra fecha, versión y dirección IP.")}</li>
                <li>
                  {gettext("Los consentimientos revocados se mantienen como registro histórico.")}
                </li>
                <li>{gettext("La revocación se registra en el audit log.")}</li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Restricción de procesamiento (Art. 18)")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Puedes restringir el procesamiento de tus datos sin eliminarlos. Mientras la restricción esté activa, no se procesarán webhooks ni eventos."
                )}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">
                {gettext("Desde el navegador")}:
              </p>
              <p class="text-slate-600 text-sm mb-3">
                {gettext("Sección «Cuenta» → «Protección de datos» → «Restringir procesamiento»")}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">{gettext("Vía API")}:</p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre
                  class="text-sm text-slate-100 font-mono whitespace-pre"
                  phx-no-curly-interpolation
                ># POST /api/v1/me/restrict — Restringir procesamiento
curl -X POST -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"password":"your_password"}' \
  <%= gettext("https://tu-dominio.com") %>/api/v1/me/restrict

# DELETE /api/v1/me/restrict — Levantar restricción
curl -X DELETE -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  <%= gettext("https://tu-dominio.com") %>/api/v1/me/restrict</pre>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Derecho de oposición (Art. 21)")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Puedes objetar al procesamiento de tus datos personales. Los workers y webhooks dejarán de procesar datos mientras la oposición esté activa."
                )}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">
                {gettext("Desde el navegador")}:
              </p>
              <p class="text-slate-600 text-sm mb-3">
                {gettext("Sección «Cuenta» → «Protección de datos» → «Objetar procesamiento»")}
              </p>
              <p class="text-slate-700 text-sm font-medium mb-2">{gettext("Vía API")}:</p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre
                  class="text-sm text-slate-100 font-mono whitespace-pre"
                  phx-no-curly-interpolation
                ># POST /api/v1/me/object — Registrar oposición
curl -X POST -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  <%= gettext("https://tu-dominio.com") %>/api/v1/me/object

# DELETE /api/v1/me/object — Restaurar consentimiento
curl -X DELETE -H "Authorization: Bearer YOUR_JWT_TOKEN" \
  <%= gettext("https://tu-dominio.com") %>/api/v1/me/object</pre>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Derecho de supresión")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Al eliminar tu cuenta desde «Cuenta» → «Eliminar cuenta», se borran permanentemente:"
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext(
                    "Todos tus proyectos y sus datos asociados (webhooks, eventos, entregas, jobs, API keys)."
                  )}
                </li>
                <li>{gettext("Membresías de equipos.")}</li>
                <li>{gettext("Tokens de sesión y notificaciones.")}</li>
                <li>
                  {gettext(
                    "Los registros de auditoría se pseudonimizan (se elimina identificador e IP)."
                  )}
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <%!-- ROPA — Registro de actividades Art. 30                       --%>
      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <section id="ropa" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Registro de actividades (Art. 30)")}
            </h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Registro de actividades de tratamiento de datos personales según el Artículo 30 del RGPD (ROPA)."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Este registro documenta todas las actividades de tratamiento de datos personales, incluyendo propósitos, bases legales, categorías de datos y periodos de retención. Documento completo disponible en docs/ROPA.md."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Actividades de tratamiento")}
              </h3>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-slate-200">
                      <th class="text-left py-2 px-3 font-semibold text-slate-700">
                        {gettext("Actividad")}
                      </th>
                      <th class="text-left py-2 px-3 font-semibold text-slate-700 hidden sm:table-cell">
                        {gettext("Base legal")}
                      </th>
                      <th class="text-left py-2 px-3 font-semibold text-slate-700 hidden sm:table-cell">
                        {gettext("Retención")}
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Registro y autenticación")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.b
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("Mientras la cuenta esté activa")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Eventos y webhooks")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.b
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("90 días (entregas)")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Registro de auditoría")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.f
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("90 días")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Gestión de sesiones")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.b
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("7 días")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Registro de consentimientos")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.c
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("Indefinido (obligación legal)")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Detección de brechas")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.f
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("90 días")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">
                        {gettext("Comunicaciones por email")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        Art. 6.1.b
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("No se almacenan")}
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Sub-procesadores")}
              </h3>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-slate-200">
                      <th class="text-left py-2 px-3 font-semibold text-slate-700">
                        {gettext("Proveedor")}
                      </th>
                      <th class="text-left py-2 px-3 font-semibold text-slate-700">
                        {gettext("Servicio")}
                      </th>
                      <th class="text-left py-2 px-3 font-semibold text-slate-700 hidden sm:table-cell">
                        {gettext("Ubicación")}
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    <tr>
                      <td class="py-2 px-3 text-slate-700 font-medium">{gettext("Supabase")}</td>
                      <td class="py-2 px-3 text-slate-600">
                        {gettext("Base de datos PostgreSQL")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("US (AWS)")}
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700 font-medium">{gettext("Resend")}</td>
                      <td class="py-2 px-3 text-slate-600">
                        {gettext("Envío de emails transaccionales")}
                      </td>
                      <td class="py-2 px-3 text-slate-600 hidden sm:table-cell">
                        {gettext("US")}
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="event-integrity" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Integridad de eventos")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Checksums SHA-256 para verificar integridad del payload y claves de idempotencia para deduplicación."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border-l-4 border-l-blue-500 bg-blue-50/50 border border-slate-200 p-5">
              <p class="text-slate-700 text-sm">
                {gettext(
                  "Cada evento incluye un hash SHA-256 del payload canónico. Opcionalmente puedes enviar una clave de idempotencia para evitar eventos duplicados."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("SHA-256 Payload Hash")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "El campo payload_hash se genera automáticamente al crear un evento. Es el hash SHA-256 hexadecimal (lowercase) del JSON canónico del payload."
                )}
              </p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre
                  class="text-sm text-slate-100 font-mono whitespace-pre"
                  phx-no-curly-interpolation
                ># POST /api/v1/events — response incluye payload_hash
curl -X POST -H "X-API-Key: YOUR_KEY" \
  -H "Content-Type: application/json" \
  -d '{"topic":"order.created","amount":150}' \
  <%= gettext("https://tu-dominio.com") %>/api/v1/events

# Response:
# {"event_id":"...","payload_hash":"a1b2c3d4..."}</pre>
              </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Clave de idempotencia")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Envía idempotency_key en el body para deduplicar eventos. Si ya existe un evento con la misma clave en el proyecto, se retorna el evento existente sin crear uno nuevo."
                )}
              </p>
              <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
                <pre
                  class="text-sm text-slate-100 font-mono whitespace-pre"
                  phx-no-curly-interpolation
                ># POST con idempotency_key — la segunda llamada retorna el mismo evento
curl -X POST -H "X-API-Key: YOUR_KEY" \
  -H "Content-Type: application/json" \
  -d '{"topic":"order.created","amount":150,"idempotency_key":"order-123-abc"}' \
  <%= gettext("https://tu-dominio.com") %>/api/v1/events</pre>
              </div>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2 mt-4">
                <li>{gettext("La clave es única por proyecto (partial unique index).")}</li>
                <li>
                  {gettext("Si la clave ya existe, se retorna el evento original con status 202.")}
                </li>
                <li>{gettext("Útil para reintentos seguros desde el cliente.")}</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="password-policy" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Política de contraseñas")}
            </h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Reglas de seguridad para contraseñas: requisitos mínimos, blacklist de contraseñas comunes e historial de contraseñas."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Requisitos de contraseña")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("Mínimo 8 caracteres, máximo 72.")}</li>
                <li>{gettext("Al menos una letra minúscula, una mayúscula y un dígito.")}</li>
                <li>
                  {gettext(
                    "No puede ser una contraseña común (blacklist de +150 contraseñas populares)."
                  )}
                </li>
                <li>
                  {gettext("No puede coincidir con contraseñas usadas anteriormente (historial).")}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Blacklist de contraseñas comunes")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Se verifica que la contraseña no esté en una lista de contraseñas comunes compilada en tiempo de build. La verificación es case-insensitive."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Historial de contraseñas")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Al cambiar o restablecer la contraseña, se verifica contra las contraseñas utilizadas anteriormente. Si coincide, se rechaza el cambio."
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("El historial se crea automáticamente al registrarse.")}</li>
                <li>{gettext("Cada cambio exitoso guarda el hash anterior en el historial.")}</li>
                <li>
                  {gettext(
                    "Aplica tanto al cambio desde la cuenta como al restablecimiento por token."
                  )}
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="uptime-monitoring" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">
              {gettext("Monitoreo de disponibilidad")}
            </h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "El sistema verifica automáticamente su estado de forma continua y registra métricas de disponibilidad."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Verificaciones realizadas")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("Conectividad a la base de datos")}</li>
                <li>{gettext("Procesador de trabajos en segundo plano")}</li>
                <li>{gettext("Sistema de caché en memoria")}</li>
                <li>{gettext("Estado del último backup")}</li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Estados del sistema")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 mr-1"></span>
                  <strong>{gettext("Saludable")}</strong>
                  — {gettext("Todos los servicios funcionando correctamente.")}
                </li>
                <li>
                  <span class="inline-block w-2 h-2 rounded-full bg-amber-500 mr-1"></span>
                  <strong>{gettext("Degradado")}</strong>
                  — {gettext(
                    "Servicios secundarios con problemas (Oban o cache). La funcionalidad principal sigue disponible."
                  )}
                </li>
                <li>
                  <span class="inline-block w-2 h-2 rounded-full bg-red-500 mr-1"></span>
                  <strong>{gettext("No saludable")}</strong>
                  — {gettext(
                    "La base de datos no responde. El sistema no puede operar normalmente."
                  )}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">{gettext("Dashboard")}</h3>
              <p class="text-slate-600 text-sm">
                {gettext(
                  "El dashboard muestra el estado actual del sistema con indicadores de uptime para las últimas 24 horas, 7 días y 30 días. Los administradores reciben notificaciones automáticas cuando el estado es degradado o no saludable."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="circuit-breaker" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Circuit breaker")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Protege el sistema pausando automáticamente las entregas a webhooks que fallan repetidamente."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Funcionamiento")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  {gettext(
                    "Tras varios fallos consecutivos en un webhook, el circuit breaker se abre automáticamente."
                  )}
                </li>
                <li>
                  {gettext(
                    "Mientras está abierto, las entregas se posponen temporalmente (no consumen reintentos)."
                  )}
                </li>
                <li>
                  {gettext(
                    "Después de un período de espera, se permite una entrega de prueba (estado half-open)."
                  )}
                </li>
                <li>
                  {gettext(
                    "Si la prueba es exitosa, el circuito se cierra y las entregas continúan normalmente."
                  )}
                </li>
                <li>
                  {gettext(
                    "Si la prueba falla, el circuito vuelve a abrirse por otro período de espera."
                  )}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Estados del circuito")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  <strong>closed</strong>
                  — {gettext("Normal. Las entregas se procesan sin restricción.")}
                </li>
                <li>
                  <strong>open</strong>
                  — {gettext("Pausado. Las entregas se posponen automáticamente.")}
                </li>
                <li>
                  <strong>half_open</strong>
                  — {gettext(
                    "Prueba. Se permite una entrega para verificar si el destino se recuperó."
                  )}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Notificaciones")}
              </h3>
              <p class="text-slate-600 text-sm">
                {gettext(
                  "El dueño del proyecto recibe notificaciones cuando un circuit breaker se abre o se cierra. Esto permite actuar rápidamente ante problemas en endpoints de destino."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="breach-detection" class="mb-14 scroll-mt-24">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-200 bg-slate-50/80">
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Detección de brechas")}</h2>
            <p class="text-slate-600 mt-1 text-sm">
              {gettext(
                "Monitoreo automatizado de seguridad que detecta anomalías analizando los logs de auditoría de forma continua."
              )}
            </p>
          </div>

          <div class="p-8 space-y-8">
            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Reglas de detección")}
              </h3>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>
                  <strong>{gettext("Fuerza bruta por IP")}</strong>
                  — {gettext(
                    "Múltiples intentos de login fallidos desde la misma IP en un período corto."
                  )}
                </li>
                <li>
                  <strong>{gettext("Ataque coordinado")}</strong>
                  — {gettext("Volumen anormal de intentos de login fallidos a nivel global.")}
                </li>
                <li>
                  <strong>{gettext("Exfiltración de datos")}</strong>
                  — {gettext("Volumen sospechoso de exportaciones de datos por un mismo usuario.")}
                </li>
                <li>
                  <strong>{gettext("Bloqueos de cuenta")}</strong>
                  — {gettext("Cualquier bloqueo de cuenta por exceso de intentos fallidos.")}
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Respuesta automática")}
              </h3>
              <p class="text-slate-600 text-sm">
                {gettext(
                  "Cuando se detecta una anomalía, se registra en el audit log y se notifica automáticamente a los administradores. Esto cumple con los requisitos de GDPR Art. 33 sobre detección temprana de brechas."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Notificación a autoridades (Art. 33)")}
              </h3>
              <p class="text-slate-600 text-sm">
                {gettext(
                  "Cuando se detecta una brecha de seguridad significativa, se activa el proceso de notificación a la autoridad de control dentro del plazo legal establecido por el GDPR (72 horas). El proceso incluye detección, investigación, contención y notificación formal."
                )}
              </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">
                {gettext("Notificación a usuarios afectados (Art. 34)")}
              </h3>
              <p class="text-slate-600 text-sm mb-3">
                {gettext(
                  "Cuando la brecha supone un alto riesgo para los derechos y libertades de los usuarios, se notifica directamente a los afectados. Aplica en casos de:"
                )}
              </p>
              <ul class="list-disc list-inside text-slate-700 text-sm space-y-2">
                <li>{gettext("Exfiltración confirmada de datos personales.")}</li>
                <li>{gettext("Acceso no autorizado a cuentas de usuario.")}</li>
                <li>{gettext("Compromiso de credenciales.")}</li>
              </ul>
              <p class="text-slate-600 text-sm mt-3">
                {gettext(
                  "La notificación incluye: descripción del incidente, datos afectados, medidas adoptadas y recomendaciones para el usuario."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>

      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <%!-- Session Management                                           --%>
      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <section id="session-management" class="mb-14 scroll-mt-24">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center">
            <svg
              class="w-5 h-5 text-indigo-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"
              />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Gestión de sesiones")}</h2>
            <p class="text-slate-500 text-sm mt-0.5">
              {gettext("Control de sesiones activas con revocación individual y masiva")}
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-3">{gettext("Descripción")}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                {gettext(
                  "Cada inicio de sesión (web o API) crea un registro de sesión vinculado al JWT. Las sesiones registran IP, User-Agent y tipo de dispositivo. Los usuarios pueden ver todas sus sesiones activas desde la página de cuenta y revocar sesiones individuales o cerrar todas las demás sesiones."
                )}
              </p>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-3">
                {gettext("Características")}
              </h3>
              <ul class="text-slate-600 text-sm space-y-2">
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Registro automático de sesión en login (web y API)")}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Detección de dispositivo: Desktop, Mobile, Tablet")}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Revocación individual de sesiones")}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Cerrar todas las demás sesiones (mantiene la actual)")}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext(
                    "Verificación de revocación en cada request (token rechazado si sesión revocada)"
                  )}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Limpieza automática de sesiones expiradas")}
                </li>
                <li class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {gettext("Audit trail completo para cada operación de sesión")}
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <%!-- PII Data Encryption                                          --%>
      <%!-- ══════════════════════════════════════════════════════════════ --%>
      <section id="data-encryption" class="mb-14 scroll-mt-24">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
            <svg
              class="w-5 h-5 text-amber-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
              />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-slate-900">{gettext("Cifrado de datos PII")}</h2>
            <p class="text-slate-500 text-sm mt-0.5">
              {gettext(
                "Protección de información personal identificable con cifrado estándar de la industria"
              )}
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-3">{gettext("Descripción")}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                {gettext(
                  "Todos los campos de información personal identificable (PII) se cifran en reposo usando algoritmos estándar de la industria. Los emails se indexan con hash determinístico para permitir búsquedas sin exponer el texto plano. Las contraseñas se hashean con algoritmos memory-hard recomendados por OWASP."
                )}
              </p>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-3">
                {gettext("Campos protegidos")}
              </h3>
              <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                  <thead>
                    <tr class="border-b border-slate-200">
                      <th class="text-left py-2 px-3 text-xs font-medium text-slate-500 uppercase">
                        {gettext("Dato")}
                      </th>
                      <th class="text-left py-2 px-3 text-xs font-medium text-slate-500 uppercase">
                        {gettext("Protección")}
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    <tr>
                      <td class="py-2 px-3 text-slate-700">{gettext("Email")}</td>
                      <td class="py-2 px-3">
                        <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">
                          {gettext("Cifrado + hash para búsqueda")}
                        </code>
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">{gettext("Nombre")}</td>
                      <td class="py-2 px-3">
                        <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">
                          {gettext("Cifrado en reposo")}
                        </code>
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">{gettext("Dirección IP")}</td>
                      <td class="py-2 px-3">
                        <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">
                          {gettext("Cifrado en reposo")}
                        </code>
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">{gettext("User Agent")}</td>
                      <td class="py-2 px-3">
                        <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">
                          {gettext("Cifrado en reposo")}
                        </code>
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 px-3 text-slate-700">{gettext("Contraseñas")}</td>
                      <td class="py-2 px-3">
                        <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">
                          {gettext("Hash unidireccional (memory-hard)")}
                        </code>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-3">
                {gettext("Clasificación de datos")}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                {gettext(
                  "Los datos se clasifican en 4 niveles: Público, Interno, Confidencial y Restringido. Todos los campos PII (nivel Confidencial) requieren cifrado en reposo. Los secretos y credenciales (nivel Restringido) usan cifrado o hash unidireccional."
                )}
              </p>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layouts.public>
