<!DOCTYPE html>
<html lang={assigns[:locale] || "es"} class="scroll-smooth">
  <head>
    <script nonce={assigns[:csp_nonce]}>
      (function(){
        var l = localStorage.getItem("locale") || document.cookie.replace(/(?:(?:^|.*;\s*)locale\s*=\s*([^;]*).*$)|^.*$/, "$1");
        if (l === "es" || l === "en") document.documentElement.lang = l;
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Favicon: logo en pestaña y en resultados de búsqueda (Google) --%>
    <link rel="icon" type="image/png" sizes="48x48" href={~p"/images/favicon-48x48.png"} />
    <link rel="icon" type="image/png" sizes="192x192" href={~p"/images/logo.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/logo.png"} />
    <meta name="theme-color" content="#0f172a" />
    <%!-- SEO: Brand, description, canonical, hreflang --%>
    <meta name="application-name" content="Jobcelis" />
    <meta
      name="description"
      content={
        assigns[:meta_description] ||
          "Events, webhooks and scheduled jobs platform for developers. Send events with a simple POST and trigger webhooks in real time."
      }
    />
    <link rel="canonical" href={"https://jobcelis.com#{assigns[:current_path] || "/"}"} />
    <link
      rel="alternate"
      hreflang="es"
      href={"https://jobcelis.com#{assigns[:current_path] || "/"}"}
    />
    <link
      rel="alternate"
      hreflang="en"
      href={"https://jobcelis.com#{assigns[:current_path] || "/"}"}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={"https://jobcelis.com#{assigns[:current_path] || "/"}"}
    />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <%!-- Open Graph --%>
    <meta property="og:site_name" content="Jobcelis" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={"https://jobcelis.com#{assigns[:current_path] || "/"}"} />
    <meta
      property="og:title"
      content={assigns[:page_title] || "Jobcelis · Events, webhooks and jobs"}
    />
    <meta
      property="og:description"
      content={
        assigns[:meta_description] ||
          "Events, webhooks and scheduled jobs platform for developers."
      }
    />
    <meta property="og:image" content="https://jobcelis.com/images/og-preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <%!-- Twitter Cards --%>
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={assigns[:page_title] || "Jobcelis · Events, webhooks and jobs"}
    />
    <meta
      name="twitter:description"
      content={
        assigns[:meta_description] ||
          "Events, webhooks and scheduled jobs platform for developers."
      }
    />
    <meta name="twitter:image" content="https://jobcelis.com/images/og-preview.png" />
    <%!-- Schema.org --%>
    <script type="application/ld+json" nonce={assigns[:csp_nonce]}>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Jobcelis",
        "url": "https://jobcelis.com",
        "logo": "https://jobcelis.com/images/logo.png",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Web",
        "description": "Events, webhooks and scheduled jobs platform for developers. Send events with a simple POST and trigger webhooks in real time."
      }
    </script>

    <.live_title default="Jobcelis" suffix={" · " <> gettext("Eventos, webhooks y jobs")}>
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>

    <script nonce={assigns[:csp_nonce]}>
      (() => {
        const mq = window.matchMedia("(prefers-color-scheme: dark)");

        const applySystem = () => {
          document.documentElement.setAttribute("data-theme", mq.matches ? "dark" : "light");
          document.documentElement.setAttribute("data-theme-choice", "system");
        };

        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            applySystem();
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.documentElement.setAttribute("data-theme-choice", theme);
          }
        };

        // Listen for OS theme changes — only apply if user chose "system"
        mq.addEventListener("change", () => {
          if (!localStorage.getItem("phx:theme")) applySystem();
        });

        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>

  <body>
    {@inner_content}
    <%!-- Cookie consent banner (GDPR) --%>
    <div
      id="cookie-banner"
      class="hidden fixed bottom-0 inset-x-0 z-50 p-4 sm:p-0"
      role="alert"
      aria-live="polite"
    >
      <div class="mx-auto max-w-4xl sm:mb-4 rounded-xl bg-slate-900 text-white shadow-2xl border border-slate-700 p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-4">
        <div class="flex-1 text-sm leading-relaxed">
          <p>
            {gettext(
              "Este sitio usa cookies técnicas esenciales para el funcionamiento (sesión, idioma, tema). No usamos cookies de rastreo ni publicidad."
            )}
            <a
              href="/cookies"
              class="underline text-indigo-300 hover:text-indigo-200 ml-1"
            >
              {gettext("Más información")}
            </a>
          </p>
        </div>
        <button
          data-cookie-accept
          class="shrink-0 px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium rounded-lg transition"
        >
          {gettext("Aceptar")}
        </button>
      </div>
    </div>
  </body>
</html>
